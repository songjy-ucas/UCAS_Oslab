// [P3-TASK1] Process exits
// иҝӣзЁӢиҮӘжҲ‘з»“жқҹпјҢеҪ“зЁӢеәҸ main еҮҪж•° return жҲ–иҖ…и°ғз”Ё exit() ж—¶и§ҰеҸ‘гҖӮ
void do_exit(void)
{
    // 1. иҺ·еҸ–еҪ“еүҚиҝӣзЁӢзҡ„PCB
    pcb_t *exiting_pcb = current_running;

    // ====================================================================
    // [P4-TASK3 е…ій”®ж–°еўһ] иө„жәҗеӣһж”¶
    // еҝ…йЎ»еңЁе°Ҷ CPU еҲҮжҚўеҲ°е…¶д»–иҝӣзЁӢд№ӢеүҚпјҢеӣһж”¶еҪ“еүҚиҝӣзЁӢеҚ з”Ёзҡ„жүҖжңүеҶ…еӯҳиө„жәҗ
    // ====================================================================
    
    // и°ғз”ЁдёҖдёӘиҫ…еҠ©еҮҪж•°жқҘе®ҢжҲҗжүҖжңүеҶ…еӯҳеӣһж”¶е·ҘдҪң
    free_process_memory(exiting_pcb);


    // ====================================================================
    // [P4-TASK3 е…ій”®ж–°еўһ] еҲҮжҚўеӣһеҶ…ж ёең°еқҖз©әй—ҙ
    // еҺҹеӣ пјҡexiting_pcb->pgdir еҜ№еә”зҡ„йЎөиЎЁеҶ…еӯҳеҲҡеҲҡеҸҜиғҪе·Із»Ҹиў« free_process_memory
    // еӣһж”¶дәҶгҖӮCPU дёҚиғҪеҶҚз»§з»ӯдҪҝз”ЁдёҖдёӘе·Із»Ҹиў«йҮҠж”ҫзҡ„йЎөиЎЁгҖӮ
    // жҲ‘д»¬еҝ…йЎ»е®үе…Ёең°е°Ҷ CPU зҡ„ең°еқҖз©әй—ҙеҲҮжҚўеӣһеҶ…ж ёзҡ„ж №йЎөиЎЁгҖӮ
    // ====================================================================
    
    set_satp(SATP_MODE_SV39, 0, PGDIR_PA >> NORMAL_PAGE_SHIFT);
    local_flush_tlb_all();


    // 2. е°ҶеҪ“еүҚиҝӣзЁӢзҡ„зҠ¶жҖҒи®ҫзҪ®дёә EXITEDгҖӮ
    // PCBжң¬иә«жҡӮж—¶дёҚйҮҠж”ҫпјҢзӯүеҫ…зҲ¶иҝӣзЁӢйҖҡиҝҮ waitpid еӣһж”¶гҖӮ
    exiting_pcb->status = TASK_EXITED;

    // 3. е”ӨйҶ’жӯЈеңЁзӯүеҫ…е®ғзҡ„зҲ¶иҝӣзЁӢ
    while (!list_empty(&exiting_pcb->wait_list)) {
        pcb_t *waiter_pcb = list_entry(exiting_pcb->wait_list.next, pcb_t, list);
        list_del(&waiter_pcb->list);
        waiter_pcb->status = TASK_READY;
        list_add_tail(&waiter_pcb->list, &ready_queue);
    }
    
    // еҰӮжһңжңүзҲ¶иҝӣзЁӢпјҢе№¶дё”зҲ¶иҝӣзЁӢжІЎжңүеңЁзӯүжҲ‘пјҢеҸҜд»Ҙеҗ‘зҲ¶иҝӣзЁӢеҸ‘йҖҒдҝЎеҸ·пјҲз®ҖеҢ–зүҲдёӯзңҒз•Ҙпјү

    // 4. дё»еҠЁж”ҫејғCPUпјҢи°ғз”Ёи°ғеәҰеҷЁ
    // жӯӨж—¶еҪ“еүҚиҝӣзЁӢе·Із»ҸжҳҜ EXITED жҖҒпјҢе®ғеҶҚд№ҹдёҚдјҡиў«и°ғеәҰеҲ°дәҶгҖӮ
    do_scheduler(); 

    // do_scheduler ж°ёиҝңдёҚдјҡиҝ”еӣһеҲ°иҝҷйҮҢ
    // еӣ дёәеҪ“еүҚиҝӣзЁӢзҡ„дёҠдёӢж–Үе·Із»Ҹиў«еҲҮжҚўеҮәеҺ»дәҶпјҢе№¶дё”еҶҚд№ҹдёҚдјҡиў«еҲҮжҚўеӣһжқҘгҖӮ
    printk("FATAL: Should not return from do_scheduler in do_exit!\n");
    assert(0);
}

// [P3-TASK1] Kill a process
// жқҖжӯ»жҢҮе®ҡиҝӣзЁӢ ------- зү№еҲ«жіЁж„ҸпјҡжқҖжӯ»иҝӣзЁӢйңҖиҰҒйҮҠж”ҫд»Җд№ҲдёңиҘҝпјҹ е®ғеҚ жҚ®зҡ„й”ҒиҰҒйҮҠж”ҫ
// [P3-TASK1] Kill a process
int do_kill(pid_t pid)
{
    if (pid <= 0) {
        return 0; 
    }

    pcb_t *target_pcb = NULL;
    for (int i = 0; i < NUM_MAX_TASK; ++i) {
        if (pcb[i].pid == pid) {
            target_pcb = &pcb[i];
            break;
        }
    }

    // еҰӮжһңиҝӣзЁӢдёҚеӯҳеңЁжҲ–е·Із»ҸжҳҜйҖҖеҮәзҠ¶жҖҒпјҢзӣҙжҺҘиҝ”еӣһ
    if (target_pcb == NULL || target_pcb->status == TASK_EXITED) {
        return 0; 
    }

    // йҮҠж”ҫй”Ғ
    check_and_release_locks(target_pcb->pid); 

    // ====================================================================
    // [дҝ®еӨҚзӮ№ 1] йҮҠж”ҫзӣ®ж ҮиҝӣзЁӢзҡ„еҶ…еӯҳиө„жәҗ
    // ж— и®әжҳҜиҮӘжқҖиҝҳжҳҜд»–жқҖпјҢиҝҷдәӣзү©зҗҶйЎөйғҪеә”иҜҘиў«еӣһж”¶
    // ====================================================================
    free_process_memory(target_pcb);

    // дҝқеӯҳж—§зҠ¶жҖҒ
    task_status_t old_status = target_pcb->status;

    // ж Үи®°дёә EXITED
    target_pcb->status = TASK_EXITED;

    // е”ӨйҶ’зҲ¶иҝӣзЁӢ
    while (!list_empty(&target_pcb->wait_list)) {
        list_node_t *waiter_node = target_pcb->wait_list.next;
        list_del(waiter_node); 
        pcb_t *waiter_pcb = list_entry(waiter_node, pcb_t, list);
        waiter_pcb->status = TASK_READY;
        list_add_tail(&waiter_pcb->list, &ready_queue);
    }

    // ====================================================================
    // [дҝ®еӨҚзӮ№ 2] еӨ„зҗҶи°ғеәҰе’ҢйЎөиЎЁеҲҮжҚў
    // ====================================================================
    if (target_pcb == current_running) {
        // CASE A: иҮӘжқҖ (Kill Self)
        // ж—ўз„¶дёҠйқўе·Із»Ҹ free_process_memory еӣһж”¶дәҶиҮӘе·ұзҡ„йЎөиЎЁ
        // иҝҷйҮҢеҝ…йЎ»з«ӢеҲ»еҲҮжҚўеӣһеҶ…ж ёйЎөиЎЁпјҢеҗҰеҲҷ CPU дјҡеҙ©жәғ
        set_satp(SATP_MODE_SV39, 0, PGDIR_PA >> NORMAL_PAGE_SHIFT);
        local_flush_tlb_all();

        // дё»еҠЁи®©еҮә CPU
        do_scheduler();
    } else {
        // CASE B: д»–жқҖ (Kill Others)
        // еҸӘйңҖиҰҒе°Ҷе…¶д»Һе°ұз»Ә/йҳ»еЎһйҳҹеҲ—дёӯз§»йҷӨ
        if (old_status == TASK_READY || old_status == TASK_BLOCKED) {
            list_del(&target_pcb->list);
        }
    }
    return 1; // Success
}

// [P3-TASK1] Wait for a child process
// зӯүеҫ…еӯҗиҝӣзЁӢз»“жқҹ,е®һзҺ°дәҶзҲ¶иҝӣзЁӢеҜ№еӯҗиҝӣзЁӢзҡ„еӣһж”¶жңәеҲ¶пјҢйҳІжӯўеғөе°ёиҝӣзЁӢжіӣж»ҘгҖӮ
int do_waitpid(pid_t pid)
{
    // жҹҘжүҫзӣ®ж ҮеӯҗиҝӣзЁӢ
    pcb_t *child_pcb = NULL;
    for (int i = 0; i < NUM_MAX_TASK; ++i) {
        if (pcb[i].pid == pid) {
            child_pcb = &pcb[i];
            break;
        }
    }

    // жІЎжүҫеҲ°пјҢжҲ–иҖ…иҝҷдёӘиҝӣзЁӢдёҚжҳҜжҲ‘зҡ„еӯҗиҝӣзЁӢпјҢе°ұдёҚз®Ўе®ғ
    if (child_pcb == NULL || child_pcb->parent_pid != current_running->pid) {
        return -1; // Not found or not a child
    }

    // жЈҖжҹҘеӯҗиҝӣзЁӢзҠ¶жҖҒ
    if (child_pcb->status == TASK_EXITED) {
        // еӯҗиҝӣзЁӢе·Із»Ҹжӯ»дәҶпјҲж—©е·ІжҳҜеғөе°ёиҝӣзЁӢпјүгҖӮйӮЈд№ҲжҲ‘зӣҙжҺҘеӣһж”¶е®ғзҡ„иө„жәҗпјҢдёҚйңҖиҰҒйҳ»еЎһзӯүеҫ…гҖӮ
        free_pcb_resources(child_pcb);
        return pid;
    }

    // еӯҗиҝӣзЁӢиҝҳеңЁи·‘гҖӮ
    // еҪ“еүҚиҝӣзЁӢпјҲзҲ¶иҝӣзЁӢпјүеҝ…йЎ»йҳ»еЎһиҮӘе·ұпјҲBLOCKEDпјүпјҢзӣҙеҲ°еӯҗиҝӣзЁӢйҖҖеҮәгҖӮе°ҶиҮӘе·ұеҠ е…ҘеӯҗиҝӣзЁӢзҡ„ wait_list дёӯгҖӮ
    current_running->status = TASK_BLOCKED;
    list_add_tail(&current_running->list, &child_pcb->wait_list);
    
    // и®©еҮә CPU и°ғз”Ёи°ғеәҰеҷЁеҲҮжҚўеҲ«зҡ„иҝӣзЁӢиҝҗиЎҢгҖӮ
    do_scheduler();

    // еҸҲеӣһеҲ°зҲ¶иҝӣзЁӢж—¶пјҢиҜҙжҳҺеӯҗиҝӣзЁӢе·Із»ҸйҖҖеҮәдәҶпјҲеңЁ do_exit йҮҢе”ӨйҶ’дәҶжҲ‘пјүгҖӮзҺ°еңЁеҸҜд»Ҙе®үе…Ёең°еӣһж”¶еӯҗиҝӣзЁӢзҡ„ PCB иө„жәҗдәҶгҖӮ
    free_pcb_resources(child_pcb);

    return pid;
}

// жҳҫзӨәиҝӣзЁӢеҲ—иЎЁ (ps е‘Ҫд»Ө)
void do_process_show()
{
    printk("[Process Table]:\n");
    
    // йҒҚеҺҶжүҖжңүеҸҜиғҪзҡ„ PCB
    for (int i = 0; i < NUM_MAX_TASK; ++i) {
        // жЈҖжҹҘPCBжҳҜеҗҰиў«дҪҝз”Ё (pid != -1) дё”дёҚжҳҜе·Із»Ҹе®Ңе…Ёжё…зҗҶзҡ„еғөе°ё
        if (pcb[i].pid != -1 && pcb[i].status != TASK_EXITED) {
            char *status_str;
            // е°Ҷж•°еӯ—зҠ¶жҖҒиҪ¬жҚўдёәеҸҜиҜ»зҡ„еӯ—з¬ҰдёІ
            switch (pcb[i].status) {
                case TASK_BLOCKED:
                    status_str = "BLOCKED"; 
                    break;
                case TASK_RUNNING:
                    status_str = "RUNNING"; 
                    break;
                case TASK_READY:
                    status_str = "READY  ";   // еҠ з©әж јжҳҜдёәдәҶеҜ№йҪҗзҫҺи§Ӯ
                    break;
                default:
                    status_str = "UNKNOWN";
                    break;
            }
            
            // [Task 4] жү“еҚ°жү©еұ•дҝЎжҒҜпјҡmask е’Ң core_id
            // жіЁж„ҸпјҡеҸӘжңү RUNNING зҠ¶жҖҒзҡ„д»»еҠЎпјҢRunning on core жүҚжңүе®һйҷ…ж„Ҹд№ү
            // дҪҶдёәдәҶи°ғиҜ•ж–№дҫҝпјҢйҖҡеёёйғҪжү“еҚ°еҮәжқҘпјҢжҲ–иҖ…жҳҫзӨәдёҠж¬ЎиҝҗиЎҢзҡ„ж ё
            printk("[%d] PID : %d  STATUS : %s  mask : 0x%x  Running on core %d\n", 
                   i,            
                   pcb[i].pid,   
                   status_str,
                   pcb[i].mask,
                   pcb[i].core_id);  
        }
    }
}

