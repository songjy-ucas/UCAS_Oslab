pid_t do_getpid()
{
    return current_running->pid;
}


/* =========================================================================
 *                         еҗҢжӯҘеҺҹиҜӯпјҡеұҸйҡң (Barrier)
 * ========================================================================= */
barrier_t barriers[BARRIER_NUM];

void init_barriers(void)
{
    for (int i = 0; i < BARRIER_NUM; i++)
    {
        barriers[i].key = -1; // -1 иЎЁзӨәиҜҘж§ҪдҪҚжңӘдҪҝз”Ё
        barriers[i].goal = 0; // зӣ®ж ҮеҲ°иҫҫж•°йҮҸ
        barriers[i].current_count = 0; // еҪ“еүҚе·ІеҲ°иҫҫж•°йҮҸ
        list_init(&barriers[i].wait_queue); // еҲқе§ӢеҢ–зӯүеҫ…йҳҹеҲ—
    }
}

// еҲқе§ӢеҢ–дёҖдёӘеұҸйҡң
int do_barrier_init(int key, int goal)
{
    // 1. жЈҖжҹҘжҳҜеҗҰе·Із»ҸеӯҳеңЁиҜҘ key зҡ„ barrierпјҢеҰӮжһңжңүзӣҙжҺҘиҝ”еӣһзҙўеј•
    for (int i = 0; i < BARRIER_NUM; i++)
    {
        if (barriers[i].key == key)
        {
            return i;
        }
    }

    // 2. еҜ»жүҫдёҖдёӘз©әзҡ„ж§ҪдҪҚеҲӣе»әж–°зҡ„ barrier
    for (int i = 0; i < BARRIER_NUM; i++)
    {
        if (barriers[i].key == -1)
        {
            barriers[i].key = key;
            barriers[i].goal = goal;
            barriers[i].current_count = 0;
            list_init(&barriers[i].wait_queue);
            return i;
        }
    }

    return -1; 
}

// жңӘе…ЁеҲ°ж—¶зӯүеҫ…еұҸйҡңпјҢе…ЁеҲ°еҗҺе”ӨйҶ’жүҖжңүиҝӣзЁӢ
void do_barrier_wait(int bar_idx)
{
    if (bar_idx < 0 || bar_idx >= BARRIER_NUM) return;
    
    barrier_t *bar = &barriers[bar_idx];

    // еўһеҠ еҲ°иҫҫи®Ўж•°
    bar->current_count++;

    if (bar->current_count >= bar->goal)
    {
        // еұҸйҡңд»»еҠЎе®ҢжҲҗгҖӮйҮҚзҪ®и®Ўж•°еҷЁд»ҘдҫҝеӨҚз”ЁпјҢе№¶е”ӨйҶ’жүҖжңүеңЁжҺ’йҳҹзҡ„е…„ејҹиҝӣзЁӢгҖӮ
        bar->current_count = 0;
        
        while (!list_empty(&bar->wait_queue))
        {
            // йҖҗдёӘе”ӨйҶ’йҳҹйҰ–зҡ„иҝӣзЁӢ
            do_unblock(bar->wait_queue.next);
        }
    }
    else
    {
        // йҳ»еЎһпјҢиҝӣе…Ҙзӯүеҫ…йҳҹеҲ—
        do_block(&current_running->list, &bar->wait_queue);
        // иҝҷйҮҢзҡ„ do_scheduler дјҡеҜјиҮҙдёҠдёӢж–ҮеҲҮжҚўпјҢеҪ“еүҚиҝӣзЁӢжҡӮеҒңгҖӮ
        do_scheduler();
    }
}

void do_barrier_destroy(int bar_idx)
{
    if (bar_idx < 0 || bar_idx >= BARRIER_NUM) return;
    
    // з®ҖеҚ•ең°ж Үи®°дёәжңӘдҪҝз”ЁпјҢйҮҠж”ҫж§ҪдҪҚ
    barriers[bar_idx].key = -1;
    barriers[bar_idx].goal = 0;
    barriers[bar_idx].current_count = 0;
}

/* =========================================================================
 *                     еҗҢжӯҘеҺҹиҜӯпјҡжқЎд»¶еҸҳйҮҸ (Condition Variable)
 * ========================================================================= */

condition_t conditions[CONDITION_NUM];

void init_conditions(void)
{
    for (int i = 0; i < CONDITION_NUM; i++)
    {
        conditions[i].key = -1;
        list_init(&conditions[i].wait_queue);
    }
}

// еҲқе§ӢеҢ–жқЎд»¶еҸҳйҮҸпјҢйҖ»иҫ‘еҗҢ Barrier
int do_condition_init(int key)
{
    // 1. жҹҘжүҫжҳҜеҗҰеӯҳеңЁ
    for (int i = 0; i < CONDITION_NUM; i++)
    {
        if (conditions[i].key == key)
        {
            return i;
        }
    }

    // 2. еҜ»жүҫз©әдҪҚ
    for (int i = 0; i < CONDITION_NUM; i++)
    {
        if (conditions[i].key == -1)
        {
            conditions[i].key = key;
            list_init(&conditions[i].wait_queue);
            return i;
        }
    }

    return -1;
}

// жқЎд»¶зӯүеҫ…wait   cond_idx: жқЎд»¶еҸҳйҮҸзҙўеј• mutex_idx: еҪ“еүҚжҢҒжңүзҡ„дә’ж–Ҙй”Ғзҙўеј•
void do_condition_wait(int cond_idx, int mutex_idx)
{
    if (cond_idx < 0 || cond_idx >= CONDITION_NUM) return;

    condition_t *cond = &conditions[cond_idx];

    // зӯүжқЎд»¶ж»Ўи¶і---> йҳ»еЎһеҪ“еүҚиҝӣзЁӢ
    do_block(&current_running->list, &cond->wait_queue);

    // еңЁйҳ»еЎһеүҚпјҢеҝ…йЎ»йҮҠж”ҫжҢҒжңүзҡ„дә’ж–Ҙй”ҒпјҒйҒҝе…ҚйҖ жҲҗжӯ»й”ҒгҖӮ
    do_mutex_lock_release(mutex_idx);

    // и°ғеәҰ (и®©еҮә CPU) иҝӣзЁӢеңЁжӯӨеӨ„жҡӮеҒңпјҢзӣҙеҲ° do_condition_signal/broadcast е”ӨйҶ’е®ғгҖӮ
    do_scheduler();

    // е”ӨйҶ’еҗҺпјҢйҮҚж–°з«һдәүе№¶иҺ·еҸ–дә’ж–Ҙй”ҒгҖӮ
    do_mutex_lock_acquire(mutex_idx);
}

// signalж“ҚдҪң 
void do_condition_signal(int cond_idx)
{
    if (cond_idx < 0 || cond_idx >= CONDITION_NUM) return;

    condition_t *cond = &conditions[cond_idx];

    // еҰӮжһңжңүзӯүзҡ„иҝӣзЁӢпјҢе”ӨйҶ’йҳҹеҲ—дёӯзҡ„з¬¬дёҖдёӘзӯүеҫ…иҖ…
    if (!list_empty(&cond->wait_queue))
    {
        do_unblock(cond->wait_queue.next);
    }
}

// broadcastж“ҚдҪң
void do_condition_broadcast(int cond_idx)
{
    if (cond_idx < 0 || cond_idx >= CONDITION_NUM) return;

    condition_t *cond = &conditions[cond_idx];

    // йҒҚеҺҶйҳҹеҲ—пјҢе”ӨйҶ’жүҖжңүеңЁзӯүеҫ…иҝҷдёӘжқЎд»¶зҡ„иҝӣзЁӢ
    while (!list_empty(&cond->wait_queue))
    {
        do_unblock(cond->wait_queue.next);
    }
}

void do_condition_destroy(int cond_idx)
{
    if (cond_idx < 0 || cond_idx >= CONDITION_NUM) return;

    conditions[cond_idx].key = -1;
}


/* =========================================================================
 *                     иҝӣзЁӢй—ҙйҖҡдҝЎпјҡдҝЎз®ұ (Mailbox)
 * ========================================================================= */

mailbox_t mboxes[MBOX_NUM];

void init_mbox()
{
    for (int i = 0; i < MBOX_NUM; i++)
    {
        mboxes[i].open_refs = 0; // жңүеӨҡе°‘дәәжү“ејҖдәҶе®ғ
        mboxes[i].name[0] = '\0';
        mboxes[i].head = 0; // иҜ»жҢҮй’Ҳ
        mboxes[i].tail = 0; // еҶҷжҢҮй’Ҳ
        mboxes[i].count = 0; // еҪ“еүҚзј“еҶІеҢәзҡ„еӯ—иҠӮж•°
        
        spin_lock_init(&mboxes[i].lock); // з”ЁиҮӘж—Ӣй”ҒдҝқжҠӨе№¶еҸ‘и®ҝй—®
        list_init(&mboxes[i].send_wait_queue); // еҸ‘йҖҒзӯүеҫ…йҳҹеҲ—пјҲж»Ўж—¶зӯүеҫ…пјү
        list_init(&mboxes[i].recv_wait_queue); // жҺҘж”¶зӯүеҫ…йҳҹеҲ—пјҲз©әж—¶зӯүеҫ…пјү
    }
}

// е»әз«Ӣжү“ејҖ
int do_mbox_open(char *name)
{
    // жҹҘжүҫжҳҜеҗҰе·ІеӯҳеңЁеҗҢеҗҚдҝЎз®ұ
    for (int i = 0; i < MBOX_NUM; i++)
    {
        if (mboxes[i].open_refs > 0 && strcmp(mboxes[i].name, name) == 0)
        {
            spin_lock_acquire(&mboxes[i].lock); 
            mboxes[i].open_refs++;
            spin_lock_release(&mboxes[i].lock);
            return i; // иҝ”еӣһдҝЎз®ұ ID
        }
    }

    // еҰӮжһңдёҚеӯҳеңЁпјҢжүҫдёҖдёӘз©әй—Іж§ҪдҪҚеҲӣе»ә
    for (int i = 0; i < MBOX_NUM; i++)
    {
        if (mboxes[i].open_refs == 0)
        {
            spin_lock_acquire(&mboxes[i].lock);
            // жӢҝй”ҒеҗҺеҶҚж¬ЎзЎ®и®Өе®ғжІЎиў«еҲ«дәәжҠўиө°
            if (mboxes[i].open_refs == 0) 
            {
                strcpy(mboxes[i].name, name);
                mboxes[i].open_refs = 1;
                mboxes[i].head = 0;
                mboxes[i].tail = 0;
                mboxes[i].count = 0;
                list_init(&mboxes[i].send_wait_queue);
                list_init(&mboxes[i].recv_wait_queue);
                
                spin_lock_release(&mboxes[i].lock);
                return i;
            }
            spin_lock_release(&mboxes[i].lock);
        }
    }

    return -1;
}

// е…ій—ӯдҝЎз®ұ
void do_mbox_close(int mbox_idx)
{
    if (mbox_idx < 0 || mbox_idx >= MBOX_NUM) return;
    
    mailbox_t *mbox = &mboxes[mbox_idx];
    
    spin_lock_acquire(&mbox->lock);
    
    if (mbox->open_refs > 0)
    {
        mbox->open_refs--; 
        if (mbox->open_refs == 0)
        {
            // еҜ№дәҺжңҖеҗҺдёҖдёӘдҪҝз”ЁиҖ…пјҢжңүд№үеҠЎйҮҠж”ҫmbox
            mbox->name[0] = '\0';
            mbox->count = 0;
            mbox->head = 0;
            mbox->tail = 0;
        }
    }
    
    spin_lock_release(&mbox->lock);
}

// з”ҹдә§иҖ…еҸ‘йҖҒ 
int do_mbox_send(int mbox_idx, void * msg, int msg_length)
{
    if (mbox_idx < 0 || mbox_idx >= MBOX_NUM) return 0;
    if (msg_length <= 0) return 0;
    // еҰӮжһңеҚ•жқЎж¶ҲжҒҜи¶…иҝҮдҝЎз®ұжҖ»е®№йҮҸпјҢиҝ”еӣһеӨұиҙҘ
    if (msg_length > MAX_MBOX_LENGTH) return 0; 

    mailbox_t *mbox = &mboxes[mbox_idx];
    char *data = (char *)msg;

    spin_lock_acquire(&mbox->lock); // дёҠй”Ғ

    // еү©дҪҷз©әй—ҙдёҚи¶іж—¶пјҢеҫӘзҺҜзӯүеҫ…
    while ( (MAX_MBOX_LENGTH - mbox->count) < msg_length )
    {
        do_block(&current_running->list, &mbox->send_wait_queue);            
        spin_lock_release(&mbox->lock); // еҝ…йЎ»ж”ҫй”Ғ еҗҰеҲҷи°ғеәҰеҮәеҺ»пјҢе…¶е®ғиҝӣзЁӢжӢҝдёҚеҲ°й”Ғе°ұжӯ»й”ҒдәҶ
        do_scheduler(); 
        spin_lock_acquire(&mbox->lock); // е”ӨйҶ’еҗҺйҮҚж–°жҠўй”ҒжЈҖжҹҘжқЎд»¶
        
        // е”ӨйҶ’еҗҺжЈҖжҹҘдҝЎз®ұжҳҜеҗҰиў«ж„ҸеӨ–е…ій—ӯ
        if (mbox->open_refs == 0) {
            spin_lock_release(&mbox->lock);
            return 0;
        }
    }

    // з©әй—ҙи¶іеӨҹдёҖж¬ЎжҖ§еҶҷе…Ҙ еҲҷеҶҷе…Ҙ
    for (int i = 0; i < msg_length; i++)
    {
        mbox->buf[mbox->tail] = data[i];
        mbox->tail = (mbox->tail + 1) % MAX_MBOX_LENGTH;
    }
    
    mbox->count += msg_length; // е·Іжңүеӯ—иҠӮж•°еўһеҠ 

    // еҶҷе…ҘдәҶж•°жҚ®пјҢе”ӨйҶ’жүҖжңүеӣ дёәз©әиҖҢзӯүеҫ…жҺҘж”¶зҡ„иҝӣзЁӢ
    while (!list_empty(&mbox->recv_wait_queue))
    {
        do_unblock(mbox->recv_wait_queue.next);
    }

    spin_lock_release(&mbox->lock);
    return msg_length; 
}

// ж¶Ҳиҙ№иҖ…жҺҘж”¶
int do_mbox_recv(int mbox_idx, void * msg, int msg_length)
{
    if (mbox_idx < 0 || mbox_idx >= MBOX_NUM) return 0;
    if (msg_length <= 0) return 0;
    
    mailbox_t *mbox = &mboxes[mbox_idx];
    char *data = (char *)msg;

    spin_lock_acquire(&mbox->lock); // дёҠй”Ғ

    // ж•°жҚ®е°‘дәҺзӣ®ж ҮиҜ»еҸ–пјҢеҫӘзҺҜзӯүеҫ…
    while (mbox->count < msg_length)
    {
        do_block(&current_running->list, &mbox->recv_wait_queue);  
        spin_lock_release(&mbox->lock); // ж”ҫй”Ғ
        do_scheduler(); 
        spin_lock_acquire(&mbox->lock);
        
        if (mbox->open_refs == 0) {
            spin_lock_release(&mbox->lock);
            return 0;
        }
    }

    // д»ҺзҺҜеҪўзј“еҶІеҢәиҜ»еҲ°з”ЁжҲ· buffer
    for (int i = 0; i < msg_length; i++)
    {
        data[i] = mbox->buf[mbox->head];
        mbox->head = (mbox->head + 1) % MAX_MBOX_LENGTH;
    }
    
    mbox->count -= msg_length;

    // е”ӨйҶ’жүҖжңүеӣ дёәж»ЎиҖҢзӯүеҫ…еҸ‘йҖҒзҡ„иҝӣзЁӢ
    while (!list_empty(&mbox->send_wait_queue))
    {
        do_unblock(mbox->send_wait_queue.next);
    }

    spin_lock_release(&mbox->lock);
    return msg_length;
}

// [Task 4] е®һзҺ° sys_taskset
// еҰӮжһң pid дёә 0пјҢдҝ®ж”№еҪ“еүҚиҝӣзЁӢпјӣеҗҰеҲҷдҝ®ж”№жҢҮе®ҡ pid иҝӣзЁӢ
void do_taskset(int mask, int pid)
{
    // еҰӮжһң mask дёә 0пјҢиҝҷйҖҡеёёжҳҜйқһжі•зҡ„
    if (mask == 0) return;

    if (pid == 0) {
        current_running->mask = mask;
    } else {
        // йҒҚеҺҶиҝӣзЁӢиЎЁжүҫеҲ°еҜ№еә” pid
        // еҒҮи®ҫ NUM_MAX_TASK жҳҜжңҖеӨ§ж”ҜжҢҒд»»еҠЎж•°
        for (int i = 0; i < NUM_MAX_TASK; i++) {
            if (pcb[i].pid == pid && pcb[i].status != TASK_EXITED) {
                pcb[i].mask = mask;
                return;
            }
        }
    }
}

// ж №жҚ®pidиҺ·еҸ–иҜҘpidеҜ№еә”зҡ„pcbзҡ„зҙўеј•
int get_pcb_index_by_pid(pid_t pid) {
    for (int i = 0; i < NUM_MAX_TASK; i++) {
        if (pcb[i].pid == pid) {
            return i;
        }
    }
    return -1; // жңӘжүҫеҲ°
}

