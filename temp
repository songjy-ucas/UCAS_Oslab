                continue; // еӨ„зҗҶе®Ңж–№еҗ‘й”®пјҢи·іиҝҮеҗҺз»ӯеёёи§„еӯ—з¬ҰеӨ„зҗҶ
            }
            /* ============================================================== */

            if (c == '\r' || c == '\n') {
                // еӣһиҪҰпјҢз»“жқҹиЎҢиҫ“е…Ҙ
                sys_write_ch('\n');
                sys_reflush();
