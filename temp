// [P3-TASK1] A/C-Core implementation of do_exec
// е®ғд»ҺзЈҒзӣҳ(й•ңеғҸ)иҜ»еҸ–зЁӢеәҸпјҢдёәе…¶еҲҶй…ҚеҶ…еӯҳ(ж Ҳ)пјҢи®ҫзҪ®еҘҪиҝҗиЎҢзҺҜеўғ(еҜ„еӯҳеҷЁ)пјҢжңҖеҗҺж”ҫе…Ҙе°ұз»ӘйҳҹеҲ—зӯүеҫ…CPUиҝҗиЎҢгҖӮ
/* kernel/syscall/syscall.c */

pid_t do_exec(char *name, int argc, char *argv[])
{
    // 1. жҹҘжүҫз©әй—І PCB 
    // дҪҝз”Ёиҫ…еҠ©еҮҪж•°пјҢз®ҖеҢ–йҖ»иҫ‘
    pcb_t *new_pcb = find_free_pcb();
    
    if (new_pcb == NULL) {
        printk("Error: No free PCB for exec!\n");
        return -1;
    }

    // 2. [Task 1] еҲӣе»әж–°йЎөиЎЁе№¶е…ұдә«еҶ…ж ёжҳ е°„ 

    //------ иҝҷдёӘе°ұжҳҜguidebookйҮҢйқўзҡ„вҖңиҰҒзӮ№и§ЈиҜ»3вҖқпјҢйңҖиҰҒдёәжҜҸдёӘз”ЁжҲ·иҝӣзЁӢжҳ е°„вҖңдёҖдёӘвҖқеҶ…ж ёйЎөиЎЁгҖӮ-----

    // allocPage иҝ”еӣһеҶ…ж ёиҷҡжӢҹең°еқҖ
    new_pcb->pgdir = allocPage(1); 
    clear_pgdir(new_pcb->pgdir);
    // е…ұдә«еҶ…ж ёй«ҳең°еқҖжҳ е°„ (д»ҺеҶ…ж ёж №йЎөиЎЁжӢ·иҙқ)
    share_pgtable(new_pcb->pgdir, pa2kva(PGDIR_PA));

    // 3. еҠ иҪҪд»»еҠЎд»Јз Ғ (и°ғз”Ё map_task)
    // map_task дјҡжҠҠзЁӢеәҸеҠ иҪҪеҲ° USER_ENTRYPOINT (0x10000)
    uint64_t entry_point = map_task(name, new_pcb->pgdir);
    if (entry_point == 0) {
        // TODO: freePage(new_pcb->pgdir)
        return -1;
    }

    // 4. еҲҶй…Қж Ҳ
    new_pcb->kernel_stack_base = allocPage(1); // еҶ…ж ёж Ҳ (еҶ…ж ёиҷҡең°еқҖ)
    
    // [Task 1] з”ЁжҲ·ж ҲеҲҶй…ҚдёҺжҳ е°„
    // A-core USER_STACK_ADDR = 0xf00010000
    // еҲҶй…Қзү©зҗҶйЎөпјҢе»әз«Ӣжҳ е°„пјҢе№¶иҝ”еӣһиҜҘйЎөзҡ„еҶ…ж ёиҷҡең°еқҖ
    uintptr_t user_stack_physical_kva = alloc_page_helper(USER_STACK_ADDR - PAGE_SIZE, new_pcb->pgdir);
    new_pcb->user_stack_base = user_stack_physical_kva; 

    // и®Ўз®—ж ҲйЎ¶жҢҮй’Ҳ
    ptr_t kernel_stack_top = new_pcb->kernel_stack_base + PAGE_SIZE;
    // user_stack_kva_top: з”ЁжҲ·ж ҲйЎ¶еҜ№еә”зҡ„еҶ…ж ёиҷҡең°еқҖ (з”ЁдәҺеҶҷеҸӮж•°)
    ptr_t user_stack_kva_top = user_stack_physical_kva + PAGE_SIZE;

    // 5. жһ„йҖ з”ЁжҲ·ж ҲеҸӮж•° (argc/argv)
    // йҖ»иҫ‘пјҡеҗ‘ user_stack_kva_top еҶҷж•°жҚ®пјҢдҪҶеңЁ argv[] йҮҢеӯҳ USER_STACK_ADDR еҒҸз§»еҗҺзҡ„ең°еқҖ
    
    int total_len = 0;
    for (int i = 0; i < argc; ++i) {
        total_len += strlen(argv[i]) + 1; 
    }

    // еӯ—з¬ҰдёІиө·е§ӢдҪҚзҪ® (еҶ…ж ёиҷҡең°еқҖ)
    ptr_t string_base = user_stack_kva_top - total_len;
    string_base &= ~0x7; 

    char *argv_new_addr[argc]; 
    char *current_str_pos = (char *)string_base;
    
    for (int i = 0; i < argc; ++i) {
        strcpy(current_str_pos, argv[i]);
        // и®Ўз®—з”ЁжҲ·иҷҡең°еқҖеҒҸз§»
        uintptr_t offset = user_stack_kva_top - (ptr_t)current_str_pos;
        argv_new_addr[i] = (char *)(USER_STACK_ADDR - offset);
        
        current_str_pos += strlen(argv[i]) + 1;
    }

    // жҢҮй’Ҳж•°з»„иө·е§ӢдҪҚзҪ® (еҶ…ж ёиҷҡең°еқҖ)
    ptr_t argv_ptr_base = string_base - sizeof(char *) * (argc + 1);
    argv_ptr_base &= ~0x7F; 

    char **argv_on_stack = (char **)argv_ptr_base;
    for (int i = 0; i < argc; ++i) {
        argv_on_stack[i] = argv_new_addr[i]; // еӯҳе…Ҙз”ЁжҲ·иҷҡең°еқҖ
    }
    argv_on_stack[argc] = NULL; 

    // и®Ўз®—жңҖз»Ҳзҡ„з”ЁжҲ·ж ҲйЎ¶ (з”ЁжҲ·иҷҡең°еқҖ)
    uintptr_t sp_offset = user_stack_kva_top - argv_ptr_base;
    ptr_t final_user_sp = USER_STACK_ADDR - sp_offset;

    // 6. еҲқе§ӢеҢ– PCB
    new_pcb->pid = process_id++;
    new_pcb->parent_pid = current_running->pid;
    new_pcb->status = TASK_READY;
    new_pcb->cursor_x = 0;
    new_pcb->cursor_y = 0;
    new_pcb->mask = current_running->mask; 
    list_init(&new_pcb->wait_list); 

    // 7. еҲқе§ӢеҢ–еҜ„еӯҳеҷЁдёҠдёӢж–Ү
    // SP е’Ң argv йғҪжҳҜз”ЁжҲ·иҷҡең°еқҖ
    init_pcb_stack(kernel_stack_top, final_user_sp, entry_point, new_pcb, argc, (char **)final_user_sp);

    // 8. еҠ е…Ҙе°ұз»ӘйҳҹеҲ—
    list_add_tail(&new_pcb->list, &ready_queue);
    
    return new_pcb->pid;
}

