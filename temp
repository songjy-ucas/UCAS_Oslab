            } else if (c == 8 || c == 127) {
                if (buffer_ptr > 0) {
                    buffer_ptr--;
                    // дҪҝз”Ё sys_write_ch е®һзҺ°еҲ йҷӨж•Ҳжһң
                    sys_write_ch('\b');
                    sys_write_ch(' ');
                    sys_write_ch('\b');
