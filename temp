 */
int ARRTIBUTE_BOOTKERNEL boot_kernel(unsigned long mhartid)
{
    // еҸӘжңү 0 еҸ·ж ё (дё»ж ё) иҙҹиҙЈеҲқе§ӢеҢ–йЎөиЎЁ
    if (mhartid == 0) {
        setup_vm();
    } else {
        // е…¶д»–ж ёзӣҙжҺҘејҖеҗҜиҷҡжӢҹеҶ…еӯҳ (еҒҮи®ҫдё»ж ёе·Із»Ҹи®ҫзҪ®еҘҪдәҶ satp жҢҮеҗ‘зҡ„йЎөиЎЁеҶ…е®№)
        enable_vm();
    }

    /* enter kernel */
    // е…ій”®и·іиҪ¬пјҒ
    // 1. _start жҳҜеҶ…ж ёе…ҘеҸЈзҡ„зү©зҗҶең°еқҖз¬ҰеҸ·
    // 2. pa2kva(_start) е°Ҷе…¶иҪ¬жҚўдёәеҶ…ж ёзҡ„й«ҳиҷҡжӢҹең°еқҖ (дҫӢеҰӮ 0xffffffc050201000)
    // 3. ејәеҲ¶иҪ¬жҚўдёәеҮҪж•°жҢҮй’Ҳе№¶и°ғз”Ё
    // иҝҷдёҖжӯҘд№ӢеҗҺпјҢPC жҢҮй’Ҳе°Ҷд»ҺдҪҺең°еқҖи·іиҪ¬еҲ°й«ҳиҷҡжӢҹең°еқҖпјҢжӯЈејҸиҝӣе…ҘеҶ…ж ёгҖӮ
    ((kernel_entry_t)pa2kva((uintptr_t)_start))(mhartid);

    return 0;
