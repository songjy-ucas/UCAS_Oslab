void free_process_memory(pcb_t *proc) 
{
    // 1. еӣһж”¶йЎөиЎЁе’Ңзү©зҗҶйЎө (дҪ еҸҜиғҪе·Із»ҸжңүдәҶзұ»дјјзҡ„ free_all_pages еҮҪж•°)
    PTE *pgd = (PTE*)proc->pgdir;
    // еҸӘеӣһж”¶з”ЁжҲ·з©әй—ҙ (VPN2 < 256)
    for (int i = 0; i < 256; i++) {
        if ((pgd[i] & _PAGE_PRESENT) == 0) continue;
        PTE *pmd = (PTE*)pa2kva(get_pa(pgd[i]));
        for (int j = 0; j < 512; j++) {
            if ((pmd[j] & _PAGE_PRESENT) == 0) continue;
            
            // жіЁж„ҸпјҡеҰӮжһң pmd[j] жҳҜдёҖдёӘеӨ§йЎөпјҢеҲҷзӣҙжҺҘеӣһж”¶пјҢдёҚз»§з»ӯеҗ‘дёӢ
            if ((pmd[j] & (_PAGE_READ | _PAGE_WRITE | _PAGE_EXEC)) != 0) {
                 freePage(pa2kva(get_pa(pmd[j])));
                 continue;
            }

            PTE *pte = (PTE*)pa2kva(get_pa(pmd[j]));
            for (int k = 0; k < 512; k++) {
                if (pte[k] & _PAGE_PRESENT) {
                    freePage(pa2kva(get_pa(pte[k])));
                } else if (pte[k] & _PAGE_SWAP) {
                    // еҰӮжһңйЎөеңЁзЈҒзӣҳдёҠпјҢеӣһж”¶е®ғеҚ з”Ёзҡ„Swapз©әй—ҙ
                    long swap_idx = get_pfn(pte[k]);
                    // free_swap_index(swap_idx); // дҪ йңҖиҰҒе®һзҺ°иҝҷдёӘеҮҪж•°
                }
            }
            freePage(pa2kva(get_pa(pmd[j]))); // еӣһж”¶L0йЎөиЎЁжң¬иә«
        }
        freePage(pa2kva(get_pa(pgd[i]))); // еӣһж”¶L1йЎөиЎЁжң¬иә«
    }
    freePage(proc->pgdir); // еӣһж”¶L2йЎөиЎЁпјҲж №йЎөиЎЁпјүжң¬иә«
    proc->pgdir = 0; // йҳІжӯўжӮ¬з©әжҢҮй’Ҳ


    // 2. [е…ій”®] еӣһж”¶жҚўйЎөзі»з»ҹзҡ„е…ғж•°жҚ®
    
    // 2.1 йҒҚеҺҶ in_mem_listпјҢз§»йҷӨеұһдәҺиҜҘиҝӣзЁӢзҡ„жүҖжңүиҠӮзӮ№
    list_node_t *current = in_mem_list.next;
    while (current != &in_mem_list) {
        alloc_info_t *info = lnode2info(current);
        list_node_t *next = current->next; // дҝқеӯҳдёӢдёҖдёӘиҠӮзӮ№
        
        if (info->pgdir_id == proc->pid) {
            delete_node_from_q(current);
            // жё…зҗҶе…ғж•°жҚ®е№¶е°Ҷе…¶ж”ҫеӣһ free_list
            info->uva = 0;
            info->pa = 0;
            info->pgdir_id = 0;
            add_node_to_q(&info->lnode, &free_list);
        }
        current = next;
    }

    // 2.2 йҒҚеҺҶ swap_out_listпјҢз§»йҷӨеұһдәҺиҜҘиҝӣзЁӢзҡ„жүҖжңүиҠӮзӮ№
    current = swap_out_list.next;
    while (current != &swap_out_list) {
        alloc_info_t *info = lnode2info(current);
        list_node_t *next = current->next;
        
        if (info->pgdir_id == proc->pid) {
            delete_node_from_q(current);
            // free_swap_index(info->on_disk_sec); // еӣһж”¶зЈҒзӣҳз©әй—ҙ
            // жё…зҗҶе…ғж•°жҚ®е№¶ж”ҫеӣһ free_list
            info->uva = 0;
            info->pa = 0;
            info->pgdir_id = 0;
            info->on_disk_sec = 0;
            add_node_to_q(&info->lnode, &free_list);
        }
        current = next;
    }

    // 3. еӣһж”¶еҶ…ж ёж Ҳ
    freePage(proc->kernel_stack_base);
    proc->kernel_sp = 0;
}

// [P4-task4] иҺ·еҸ–зі»з»ҹеҸҜз”ЁеҶ…еӯҳ
size_t do_get_free_memory()
{
    size_t free_pages = 0;
    size_t bitmap_size = TOTAL_PAGES / 8; // 65536 / 8 = 8192 еӯ—иҠӮ
    
    for (size_t i = 0; i < bitmap_size; i++) {
        uint8_t byte = page_bitmap[i];
        
        // дјҳеҢ–пјҡеҰӮжһңиҝҷдёҖдёӘеӯ—иҠӮе…ЁжҳҜ1 (0xFF)пјҢиҜҙжҳҺ8дёӘйЎөйғҪж»ЎдәҶпјҢзӣҙжҺҘи·іиҝҮ
        if (byte == 0xFF) {
            continue;
        }
        
        // еҰӮжһңеӯ—иҠӮе…ЁжҳҜ0пјҢиҜҙжҳҺ8дёӘйЎөйғҪз©әй—І
        if (byte == 0x00) {
            free_pages += 8;
            continue;
        }

        // еҗҰеҲҷйҖҗдҪҚжЈҖжҹҘ
        for (int j = 0; j < 8; j++) {
            // еҰӮжһңз¬¬ j дҪҚжҳҜ 0пјҢиҜҙжҳҺиҜҘйЎөз©әй—І
            if (((byte >> j) & 1) == 0) {
                free_pages++;
            }
        }
    }

    return free_pages * PAGE_SIZE; // иҝ”еӣһеӯ—иҠӮж•°
}
