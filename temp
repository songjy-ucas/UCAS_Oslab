    srand(sys_get_tick()); // дҪҝз”Ё get_ticks() жҲ– clock()
    // =======================================================================

    int ints_per_page = PAGE_SIZE / sizeof(int);

    // ---------------------- йҡҸжңәеҶҷе…Ҙйҳ¶ж®ө ----------------------
    printf("[PHASE 1] Start random writes to virtual pages...\n");
    for (int i = 0; i < NUM_PAGES_TO_TEST * 2; ++i) { // еўһеҠ жҖ»еҶҷе…Ҙж¬Ўж•°д»ҘжӣҙеҘҪең°жөӢиҜ•
        
