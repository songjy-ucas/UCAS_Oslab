#include <asm.h>
#include <csr.h>

#define PAGE_SIZE 4096 // 4K
#define INIT_KERNEL_STACK 0xffffffc050500000
.globl _edata
.globl _end

.section ".entry_function","ax"
ENTRY(_start)
  /* Mask all interrupts */
  csrw CSR_SIE, zero
  csrw CSR_SIP, zero
  mv s2, a0
  mv s3, a1
  csrr a0, mhartid
  bnez a0, stack_init 

  /* TODO: [p1-task2] clear BSS for flat non-ELF images */
  la s0, _edata     // еҠ иҪҪBSSж®өиө·е§Ӣең°еқҖеҲ° s0
  la s1, _end       // еҠ иҪҪBSSж®өз»“жқҹең°еқҖеҲ° s1
clear_bss_loop:
  bgeu s0, s1, bss_done // еҰӮжһң s0 >= s1пјҢиҜҙжҳҺBSSе·Іжё…з©әпјҢи·іиҪ¬еҲ° bss_done
  sw zero, 0(s0)        // е°Ҷ0еҶҷе…Ҙ s0 жҢҮеҗ‘зҡ„еҶ…еӯҳең°еқҖ (4еӯ—иҠӮ)
  addi s0, s0, 4        // s0 жҢҮй’ҲеҠ 4
  j clear_bss_loop      // з»§з»ӯеҫӘзҺҜ
bss_done:
  // -- END OF ADDED CODE FOR TASK 2 --


  /* TODO: [p1-task2] setup C environment */
  // -- BEGIN OF ADDED CODE FOR TASK 2 --
  # li sp, KERNEL_STACK
  # j main

  /* TODO: [p1-task2] setup C environment */

stack_init:

  li sp, INIT_KERNEL_STACK   // 0x50500000
  li t0, PAGE_SIZE           // 4096

  
  csrr a0, mhartid           // иҜ»еҸ– hartid
  addi a0, a0, 1             // a0 = hartid + 1
  mul t0, t0, a0             // t0 = (hartid + 1) * 4096
