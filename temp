/* ================= [Task 4] иҫ…еҠ©еҮҪж•°пјҡеҚҒе…ӯиҝӣеҲ¶еӯ—з¬ҰдёІиҪ¬ж•ҙж•° ================= */
int xtoi(const char *str) {
    int val = 0;
    // и·іиҝҮ "0x" жҲ– "0X" еүҚзјҖ
    if (str[0] == '0' && (str[1] == 'x' || str[1] == 'X')) {
        str += 2;
    }
    while (*str) {
        char c = *str;
        int digit;
        if (c >= '0' && c <= '9') digit = c - '0';
        else if (c >= 'a' && c <= 'f') digit = c - 'a' + 10;
        else if (c >= 'A' && c <= 'F') digit = c - 'A' + 10;
        else break; // йқһжі•еӯ—з¬ҰеҒңжӯўи§Јжһҗ
        val = val * 16 + digit;
        str++;
    }
    return val;
}


int parse_command(char *buffer, char *argv[])
{
    int argc = 0;
    char *p = buffer;
    while (*p && argc < MAX_ARGV) {
        // Skip leading whitespace
        while (*p && isspace(*p)) {
            *p++ = '\0';
        }
        if (*p == '\0') break;

        // Save argument
        argv[argc++] = p;

        // Find end of argument
        while (*p && !isspace(*p)) {
            p++;
        }
    }
    argv[argc] = NULL;
    return argc;
}

