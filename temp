#include <asm/biosdef.h>
#include <csr.h>

// os size location (os_size could be sectors [p1-task3] or bytes [p1-task4])
.equ os_size_loc, 0x502001fc
.equ task_num_loc, 0x502001fa       
.equ task_info_loc, 0x502001f8     

// kernel address (move kernel to here, and jmp here to start kernel)
.equ kernel, 0x50202000 // Prj4д№ӢеүҚдёә0x50201000пјҢд№ӢеҗҺдёә0x50202000

// BIOS function entry (jump here to use BIOS APIs)
.equ bios_func_entry, 0x50150000

.data
msg_boot: .string "It's songjunyi's bootloader...\n\r"

.text
.global main

main:
	// fence on all memory and I/O
	fence
    // a0 is mhartid
	bnez a0, secondary // иҝҷйҮҢе°ұжҳҜеҜ№дё»д»Һж ёзҡ„еҲҶжөҒпјҢдё»ж ёеҺ»жҗ¬kernelеҲ°еҶ…еӯҳпјҢд»Һж ёзӯүеҫ…е°ұеҸҜд»Ҙ

	// [p1-task1] call BIOS to print string
	la   a0, msg_boot
	li   a7, BIOS_PUTSTR
	li   t0, bios_func_entry
    jalr t0

	// [p1-task2] call BIOS to read kernel & apps in SD card
	li   a0, kernel           // a0: еҠ иҪҪзӣ®ж Үең°еқҖ
	
	li   t0, os_size_loc
	lh   a1, 0(t0)            // a1: д»Һе…ғж•°жҚ®еҢәиҜ»еҸ–OSеӨ§е°Ҹ (жүҮеҢәж•°)
	li   a2, 1                // a2: д»Һз¬¬1дёӘжүҮеҢәејҖе§ӢиҜ» (0жҳҜbootblock)
	li   a7, BIOS_SDREAD
	li   t0, bios_func_entry
	jalr t0

	; // [p1-task4] еҠ иҪҪд»»еҠЎзӣёе…іеҸӮж•°е№¶дј йҖ’з»ҷеҶ…ж ё
    ; // е°ҶдҝЎжҒҜеҠ иҪҪеҲ°еҸӮж•°еҜ„еӯҳеҷЁ a0 е’Ң a1
    ; li   t0, task_num_loc
    ; lh   a0, 0(t0)            // a0 = task_num

    ; li   t0, task_info_loc
    ; lh   a1, 0(t0)            // a1 = task_info_start_sector

	// [p1-task2] jump to kernel to start UCAS-OS
	li t0, kernel             // еҠ иҪҪеҶ…ж ёең°еқҖеҲ° t0
	jr t0                     // и·іиҪ¬еҲ°еҶ…ж ё

	/************************************************************/
secondary:
	/* TODO [P3-task3]: 
	 * 1. Mask all interrupts
	 * 2. let stvec pointer to kernel_main
	 * 3. enable software interrupt for ipi
	 */
    // 1. еұҸи”ҪжүҖжңүдёӯж–ӯ (жё…йҷӨ sie еҜ„еӯҳеҷЁ)
    csrw sie, zero
    csrw sip, zero

    // 2. и®ҫзҪ® stvec жҢҮеҗ‘еҶ…ж ёе…ҘеҸЈ (kernel = 0x50202000)
    // иҝҷж ·еҪ“ж”¶еҲ° IPI ж—¶пјҢзЎ¬д»¶дјҡзӣҙжҺҘи·іиҪ¬еҲ° start.S зҡ„ _start
    li t0, kernel
    csrw stvec, t0

    // 3. ејҖеҗҜиҪҜд»¶дёӯж–ӯ (SSIE)
    // sie еҜ„еӯҳеҷЁзҡ„ bit 1 жҳҜ SSIE (Supervisor Software Interrupt Enable)
    li t0, 2
    csrs sie, t0

    // 4. ејҖеҗҜе…ЁеұҖдёӯж–ӯ (sstatus.sie)
    // sstatus еҜ„еӯҳеҷЁзҡ„ bit 1 жҳҜ SIE (Supervisor Interrupt Enable)
    li t0, 2
    csrs sstatus, t0

wait_for_wakeup:
	wfi
	j wait_for_wakeup

	/************************************************************/

stop:
	j stop
	nop
