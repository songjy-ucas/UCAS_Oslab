        // [Fix] зЎ®дҝқзј“еҶІеҢәеҲқе§ӢеҢ–пјҢйҒҝе…Қи„Ҹж•°жҚ®еҪұе“Қ
        cmd_buffer[0] = '\0'; 

        while (1) {
            int c;
            while((c = sys_getchar()) == -1){
            ; // зӯүеҫ…е‘Ҫд»ӨиЎҢиҫ“е…Ҙ    
            } 
            
            /* ================= ADDED: ARROW KEYS HANDLING ================= */
            if (c == 27) { // ESC sequence
                int c2, c3;
                // гҖҗдҝ®еӨҚгҖ‘еҝ…йЎ»еҫӘзҺҜзӯүеҫ…з¬¬дәҢдёӘеӯ—з¬ҰпјҢдёҚиғҪеҒҮи®ҫе®ғе·Із»ҸеҲ°дәҶ
                while((c2 = sys_getchar()) == -1); 
                // гҖҗдҝ®еӨҚгҖ‘еҝ…йЎ»еҫӘзҺҜзӯүеҫ…з¬¬дёүдёӘеӯ—з¬Ұ
                while((c3 = sys_getchar()) == -1); 
                if (c2 == 91) { // '['
                    if (c3 == 65) { // 'A' -> Up Arrow
                         if (history_count > 0 && history_current > 0) {
                            history_current--;
                            // жё…йҷӨеҪ“еүҚиЎҢ
                            while (buffer_ptr > 0) {
                                buffer_ptr--;
                                sys_write_ch('\b'); sys_write_ch(' '); sys_write_ch('\b');
                            }
                            // еӨҚеҲ¶еҺҶеҸІе‘Ҫд»Ө
                            strcpy(cmd_buffer, history_buffer[history_current % HISTORY_MAX]);
                            buffer_ptr = strlen(cmd_buffer);
                            // жҳҫзӨә
                            printf("%s", cmd_buffer);
