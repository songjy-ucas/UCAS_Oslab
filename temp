/* [P4-Task1] ж–°еўһ: еҸ–ж¶Ҳдёҙж—¶жҳ е°„зҡ„иҫ…еҠ©еҮҪж•° */
void cancel_identity_mapping(void)
{
    /* 
     * еңЁ Sv39 жЁЎејҸдёӢпјҢ0x50200000 еҜ№еә”зҡ„иҷҡжӢҹең°еқҖйҖҡеёёдҪҚдәҺйЎ¶зә§йЎөиЎЁ(Page Directory)зҡ„з¬¬ 0 йЎ№гҖӮ
     * еӣ дёә 0 ~ 1GB зҡ„ең°еқҖйғҪеңЁз¬¬ 0 йЎ№иҰҶзӣ–иҢғеӣҙеҶ… (1GB = 1 << 30)гҖӮ
     * и®Ўз®—зҙўеј•: VPN2 = (0x50200000 >> 30) & 0x1FF = 0
     */
     
    // иҺ·еҸ–еҶ…ж ёйЎөиЎЁеҹәең°еқҖ (еҝ…йЎ»иҪ¬жҚўдёәиҷҡжӢҹең°еқҖи®ҝй—®!)
    PTE *pgdir = (PTE *)pa2kva(PGDIR_PA); 
    
    // жё…йҷӨз¬¬ 0 йЎ№ (иҰҶзӣ– 0-1GB зҡ„жҒ’зӯүжҳ е°„)
    pgdir[0] = 0; 
    
    // еҲ·ж–° TLBпјҢзЎ®дҝқ CPU дёҚеҶҚзј“еӯҳж—§зҡ„жҳ е°„
    local_flush_tlb_all();
}

