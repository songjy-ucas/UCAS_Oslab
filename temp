void do_scheduler(void)
{
    // TODO: [p2-task3] Check sleep queue to wake up PCBs

    /************************************************************/
    /* Do not touch this comment. Reserved for future projects. */
    /************************************************************/

    // TODO: [p2-task1] Modify the current_running pointer.

    // 0. иҺ·еҸ–еҪ“еүҚж ё ID (ж”ҫеңЁжңҖеүҚйқўпјҢеӣ дёәеҗҺйқўеӨҡж¬Ўз”ЁеҲ°)
    uint64_t cpu_id = get_current_cpu_id();

    // 1. жЈҖжҹҘзқЎзң йҳҹеҲ—пјҢе”ӨйҶ’еҲ°жңҹзҡ„иҝӣзЁӢ
    check_sleeping();

    // 2. иҺ·еҸ–еҪ“еүҚиҝӣзЁӢпјҲеҚіе°Ҷиў«еҲҮжҚўжҺүзҡ„иҝӣзЁӢпјүзҡ„жҢҮй’Ҳ
    pcb_t *prev = current_running;

    // 3. ж №жҚ® prev иҝӣзЁӢзҡ„еҪ“еүҚзҠ¶жҖҒпјҢеҶіе®ҡеҰӮдҪ•еӨ„зҪ®е®ғ
    if (prev->status == TASK_RUNNING) {
        // жіЁж„Ҹпјҡд»»дҪ•дёҖдёӘж ёзҡ„ idle иҝӣзЁӢ(pid0)йғҪдёҚеә”иҝӣе…Ҙе°ұз»ӘйҳҹеҲ—
        if (prev != &pid0_pcb[0] && prev != &pid0_pcb[1]) {
            prev->status = TASK_READY;
            // е°Ҷе…¶еҠ е…Ҙе°ұз»ӘйҳҹеҲ—йҳҹе°ҫ
            list_add_tail(&prev->list, &ready_queue);
        }
    }

    // 4. [Task 4 дҝ®ж”№ж ёеҝғ] д»Һе°ұз»ӘйҳҹеҲ—дёӯйҒҚеҺҶпјҢеҜ»жүҫз¬ҰеҗҲеҪ“еүҚж ё mask иҰҒжұӮзҡ„д»»еҠЎ
    pcb_t *next = NULL;
    list_node_t *current_node = ready_queue.next;

    // йҒҚеҺҶ ready_queue
    while (current_node != &ready_queue) {
        pcb_t *candidate = list_entry(current_node, pcb_t, list);

        // [Task 4] жЈҖжҹҘдәІе’ҢжҖ§ (Affinity Check)
        // йҖ»иҫ‘пјҡеҰӮжһңд»»еҠЎзҡ„ mask зҡ„з¬¬ cpu_id дҪҚжҳҜ 1пјҢиҜҙжҳҺе…Ғи®ёеңЁиҜҘж ёиҝҗиЎҢ
        if (candidate->mask & (1 << cpu_id)) {
            next = candidate;
            // жүҫеҲ°дәҶеҗҲйҖӮзҡ„д»»еҠЎпјҢе°Ҷе…¶д»ҺйҳҹеҲ—дёӯз§»йҷӨ
            list_del(current_node);
            break; // еҒңжӯўжҹҘжүҫ
        }

        // еҰӮжһңеҪ“еүҚд»»еҠЎдёҚж»Ўи¶і mask иҰҒжұӮпјҢз»§з»ӯзңӢдёӢдёҖдёӘ
        current_node = current_node->next;
    }

    // 5. еҰӮжһңйҳҹеҲ—дёәз©әпјҢжҲ–иҖ…йҳҹеҲ—йҮҢжүҖжңүд»»еҠЎйғҪдёҚе…Ғи®ёеңЁеҪ“еүҚж ёиҝҗиЎҢ
    if (next == NULL) {
        // иҝҗиЎҢеҪ“еүҚж ёеҜ№еә”зҡ„ idle д»»еҠЎ
        next = &pid0_pcb[cpu_id];
    }

    // 6. жӣҙж–° current_running жҢҮй’ҲпјҢзҠ¶жҖҒпјҢд»ҘеҸҠеҪ“еүҚиҝҗиЎҢж ёеҝғ
    next->status = TASK_RUNNING;
    next->core_id = cpu_id; // [Task 4] жӣҙж–°д»»еҠЎеҪ“еүҚжүҖеңЁзҡ„ж ё
    current_running = next;
    
    klog("Scheduler on core %d picked task '%s'(PID %d) with mask 0x%x\n",
         cpu_id,
         (next == &pid0_pcb[0] || next == &pid0_pcb[1]) ? "idle" : "user_task",
         next->pid,
         next->mask);

    // 7. и°ғз”ЁжұҮзј–е®һзҺ°зҡ„ switch_to еҮҪж•°пјҢе®ҢжҲҗдёҠдёӢж–ҮеҲҮжҚў
    // еҸӘжңүеҪ“д»»еҠЎзЎ®е®һеҸ‘з”ҹеҸҳеҢ–ж—¶жүҚиҝӣиЎҢеҲҮжҚў
    if (prev != next) {
        // [P4] 1. иҺ·еҸ–дёӢдёҖдёӘиҝӣзЁӢзҡ„йЎөзӣ®еҪ•иҷҡжӢҹең°еқҖ (Kernel Virtual Address)
        // зЎ®дҝқдҪ зҡ„ PCB з»“жһ„дҪ“дёӯжңү pgdir жҲҗе‘ҳпјҢе№¶дё”еңЁеҲӣе»әиҝӣзЁӢж—¶е·ІеҲқе§ӢеҢ–
        uintptr_t next_pgdir_kva = next->pgdir;

        // [P4] 2. иҪ¬жҚўдёәзү©зҗҶең°еқҖ (Physical Address)
        // satp еҜ„еӯҳеҷЁйңҖиҰҒзҡ„жҳҜзү©зҗҶйЎөеҸ·пјҢжүҖд»Ҙеҝ…йЎ»иҪ¬жҚў
        uintptr_t next_pgdir_pa = kva2pa(next_pgdir_kva);

        // [P4] 3. еҲҮжҚў SATP еҜ„еӯҳеҷЁ
        // дҪҝз”Ё SV39 жЁЎејҸпјҢASID и®ҫдёә 0 (з®ҖеҢ–)пјҢеЎ«е…Ҙзү©зҗҶйЎөеҸ· (PA >> 12)
        set_satp(SATP_MODE_SV39, 0, next_pgdir_pa >> NORMAL_PAGE_SHIFT);

        // [P4] 4. еҲ·ж–° TLB
        // еҝ…йЎ»ж“ҚдҪңпјҢеҗҰеҲҷ CPU иҝҳдјҡз”Ёж—§зҡ„зј“еӯҳжҹҘиЎЁпјҢеҜјиҮҙеҙ©жәғ
        local_flush_tlb_all();
        
        // debug use
        // printk("Switch: PID %d -> %d, Next PGDIR: 0x%lx\n", 
        // prev->pid, next->pid, next->pgdir);
        
        // [P4] 5. еҲҮжҚўеҜ„еӯҳеҷЁдёҠдёӢж–Ү
        switch_to(prev, next);
    }
}

void do_sleep(uint32_t sleep_time)
{
    // TODO: [p2-task3] sleep(seconds)
    // NOTE: you can assume: 1 second = 1 `timebase` ticks
    // 1. block the current_running
    // 2. set the wake up time for the blocked task
    // 3. reschedule because the current_running is blocked.
    // 1. block the current_running
    current_running->status = TASK_BLOCKED;

    // 2. set the wake up time for the blocked task
    current_running->wakeup_time = get_ticks() + (uint64_t)sleep_time * get_time_base();
    list_add_tail(&current_running->list, &sleep_queue);
    
    // 3. reschedule because the current_running is blocked.
    do_scheduler();

}

