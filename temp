    printf("[Child A] Sent success! (Deadlock failed)\n");
    sys_mbox_recv(m2, buf, MSG_LEN);
}

/* ==========================================
 * 4. иҝӣзЁӢ B зҡ„йҖ»иҫ‘ (еӯҗзЁӢеәҸ 2)
