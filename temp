uint64_t map_task(char *taskname, uintptr_t pgdir)
{
    int task_idx = -1;
    // 1. жҹҘжүҫд»»еҠЎ
    for (int i = 0; i < TASK_MAXNUM; i++) {
        if (tasks[i].name[0] != '\0' && strcmp(tasks[i].name, taskname) == 0) {
            task_idx = i;
            break;
        }
    }

    if (task_idx == -1) {
        bios_putstr("Task not found: '");
        bios_putstr((char *)taskname);
        bios_putstr("'\n\r");
        return 0;
    }

    task_info_t *info = &tasks[task_idx];

    // =============================================================
    // [дҝ®ж”№зӮ№ 1] дҪҝз”Ё p_memsz зЎ®е®ҡеҶ…еӯҳеҲҶй…ҚеӨ§е°Ҹ
    // =============================================================
    uint64_t mem_size = info->p_memsz;

    // е®үе…ЁйҳІеҫЎпјҡзҗҶи®әдёҠ p_memsz >= sizeпјҢдҪҶйҳІжӯўж•°жҚ®ејӮеёёпјҢеҒҡдёӘдҝқеә•
    if (mem_size < info->size) {
        mem_size = info->size;
    }

    // и®Ўз®—йңҖиҰҒжҳ е°„зҡ„иҷҡжӢҹең°еқҖдёҠйҷҗпјҲеҗ‘дёҠеҜ№йҪҗеҲ° PAGE_SIZEпјү
    // жҜ”еҰӮ mem_size = 0x1234, еҜ№йҪҗеҗҺ alloc_limit = 0x2000
    uint64_t alloc_limit = (mem_size + PAGE_SIZE - 1) & ~(PAGE_SIZE - 1);

    // =============================================================
    // [дҝ®ж”№зӮ№ 2] е»әз«Ӣе®Ңж•ҙзҡ„йЎөиЎЁжҳ е°„ (еҢ…еҗ« д»Јз Ғж®ө + ж•°жҚ®ж®ө + BSS)
    // =============================================================
    uint64_t user_va_start = USER_ENTRYPOINT;
    
    for (uint64_t va = user_va_start; va < user_va_start + alloc_limit; va += PAGE_SIZE) {
        // иҝҷйҮҢеҲҶй…Қзү©зҗҶйЎөе№¶е»әз«Ӣжҳ е°„гҖӮ
        // е…ій”®зӮ№пјҡalloc_page_helper еҶ…йғЁеҝ…йЎ»дҝқиҜҒеҲҶй…ҚеҮәзҡ„зү©зҗҶйЎөжҳҜжё…йӣ¶зҡ„пјҒ
        // иҝҷж ·пјҢmem_size > size зҡ„йғЁеҲҶпјҲBSSж®өпјүиҮӘеҠЁе°ұиў«еЎ«жҲҗ 0 дәҶгҖӮ
        alloc_page_helper(va, pgdir);
    }

    // =============================================================
    // 3. иҜ»еҸ–ж•°жҚ®е№¶жӢ·иҙқ (иҝҷйғЁеҲҶеҹәжң¬дёҚз”ЁеҸҳпјҢдҪҶйҖ»иҫ‘жӣҙжё…жҷ°дәҶ)
    // =============================================================
    // жіЁж„ҸпјҡеҸӘжӢ·иҙқзЈҒзӣҳдёҠеӯҳеңЁзҡ„ info->size еӨ§е°ҸпјҢдёҚиҰҒжӢ·иҙқ mem_sizeпјҒ
    
    uint32_t start_sector = info->offset / SECTOR_SIZE;
    uint32_t end_sector = (info->offset + info->size - 1) / SECTOR_SIZE;
    uint32_t num_sectors = end_sector - start_sector + 1;

    // иҜ»еҸ– SD еҚЎж•°жҚ®еҲ°еҶ…ж ёдёҙж—¶зј“еҶІеҢә
    bios_sd_read(TMP_MEM_BASE, num_sectors, start_sector);

    uint32_t offset_in_sector = info->offset % SECTOR_SIZE;
    uintptr_t src_ptr = pa2kva(TMP_MEM_BASE) + offset_in_sector;

    uint64_t remain_size = info->size; // еҸӘеӨ„зҗҶж–Үд»¶еӨ§е°Ҹ
    uint64_t current_va = user_va_start;

    while (remain_size > 0) {
        // иҺ·еҸ–зӣ®ж ҮйЎөзҡ„еҶ…ж ёиҷҡжӢҹең°еқҖ (еӣ дёәдёҠйқўе·Із»Ҹе…ЁйҮҸеҲҶй…ҚиҝҮдәҶпјҢиҝҷйҮҢеҸӘжҳҜдёәдәҶжӢҝеҲ°ең°еқҖиҝӣиЎҢ memcpy)
        uintptr_t dest_page_kva = alloc_page_helper(current_va, pgdir);
        
        uint64_t page_offset = current_va % PAGE_SIZE;
        uint64_t page_remain = PAGE_SIZE - page_offset;
        uint64_t copy_len = (remain_size < page_remain) ? remain_size : page_remain;

        memcpy((void *)(dest_page_kva + page_offset), (void *)src_ptr, copy_len);

        remain_size -= copy_len;
        current_va += copy_len;
        src_ptr += copy_len;
    }

    // жӯӨж—¶пјҡ
    // [USER_ENTRYPOINT, USER_ENTRYPOINT + info->size) -> еЎ«ж»ЎдәҶд»Јз Ғе’Ңж•°жҚ®
    // [USER_ENTRYPOINT + info->size, USER_ENTRYPOINT + alloc_limit) -> д№ӢеүҚ alloc ж—¶е·Іжё…йӣ¶ (BSS)

    return USER_ENTRYPOINT;
