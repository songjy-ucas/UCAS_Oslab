                printf("   - Got value:       0x%x (%d)\n\n", current_value, current_value);
                error_found = 1;
                goto end_test; // еҸ‘зҺ°дёҖдёӘй”ҷиҜҜе°ұеҒңжӯў
            }
        }
        // printf("OK.\n");
    }

end_test:
    printf("[PHASE 2] Verification phase completed.\n\n");
    if (error_found) {
