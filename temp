    /* Initialize registers on kernel stack */
    regs_context_t *pt_regs =
        (regs_context_t *)(kernel_stack - sizeof(regs_context_t));
    
    // жё…з©әжүҖжңүеҜ„еӯҳеҷЁпјҢйҳІжӯўжңүеһғеңҫж•°жҚ®
    memset(pt_regs, 0, sizeof(regs_context_t));

    /* и®ҫзҪ®е…ій”®еҜ„еӯҳеҷЁ */
    pt_regs->regs[2] = user_stack;       // sp: з”ЁжҲ·ж ҲйЎ¶
    pt_regs->regs[4] = (reg_t)pcb;       // tp: жҢҮеҗ‘еҪ“еүҚ PCB
    pt_regs->regs[10] = (reg_t)argc;     // a0: еҸӮж•°дёӘж•°
    pt_regs->regs[11] = (reg_t)argv;     // a1: еҸӮж•°ж•°з»„жҢҮй’Ҳ

    pt_regs->sepc = entry_point;         // sepc: з”ЁжҲ·зЁӢеәҸе…ҘеҸЈең°еқҖ
    
    // и®ҫзҪ® sstatus:
    pt_regs->sstatus = SR_SPIE | SR_SUM;  // SPIE set to 1

    /* жЁЎжӢҹ switch_to зҡ„дёҠдёӢж–Ү */
    switchto_context_t *pt_switchto =
        (switchto_context_t *)((ptr_t)pt_regs - sizeof(switchto_context_t));
    
    // жё…з©ә switch_to дёҠдёӢж–Ү
    memset(pt_switchto, 0, sizeof(switchto_context_t));

    // ra жҢҮеҗ‘ејӮеёёиҝ”еӣһе…ҘеҸЈпјҢиҝҷж ·з¬¬дёҖж¬Ўи°ғеәҰеҲ°иҜҘиҝӣзЁӢж—¶пјҢ
    // жү§иЎҢ ret дјҡи·іиҪ¬еҲ° ret_from_exceptionпјҢ
    // иҝӣиҖҢжү§иЎҢ RESTORE_CONTEXT е№¶ sret иҝӣе…Ҙз”ЁжҲ·жҖҒгҖӮ
    pt_switchto->regs[0] = (reg_t)&ret_from_exception; // ra

    // дҝқеӯҳжңҖз»Ҳзҡ„еҶ…ж ёж ҲйЎ¶жҢҮй’ҲеҲ° PCB
    pcb->kernel_sp = (reg_t)pt_switchto;
    pcb->user_sp = user_stack;

    // [Task 4] Mask Initialization
    // й»ҳи®Өжғ…еҶөдёӢпјҢз»§жүҝзҲ¶иҝӣзЁӢзҡ„ maskпјҢеҰӮжһңжҳҜз¬¬дёҖдёӘиҝӣзЁӢеҲҷе…Ғи®ёжүҖжңүж ё
    if (current_running) {
        pcb->mask = current_running->mask;
    } else {
        pcb->mask = 0x3; // е…Ғи®ё Core 0 е’Ң Core 1
    }
    pcb->core_id = -1; // е°ҡжңӘиҝҗиЎҢ
}

static void init_pcb(void)
{
    /* еҲқе§ӢеҢ– PCB ж•°з»„е’Ңе°ұз»ӘйҳҹеҲ— */
    list_init(&ready_queue);
    list_init(&sleep_queue);
    for (int i = 0; i < NUM_MAX_TASK; i++) {
        memset(&pcb[i], 0, sizeof(pcb_t));
        pcb[i].pid = -1;
    }

    /* еҠ иҪҪз”ЁжҲ·д»»еҠЎ (Shell) */
    const char *task_names[] = {"shell"};
    int pcb_idx = 1; // иҝҷйҮҢзҡ„ 1 жҳҜзЎ¬зј–з Ғзҡ„пјҢжҢҮе®ҡ Shell еҚ з”Ё pcb[1]

    // =============================================================
    // [дҝ®ж”№ 2] дёә Shell еҲӣе»әйЎөиЎЁе№¶е…ұдә«еҶ…ж ёжҳ е°„
    // =============================================================
    pcb[pcb_idx].pgdir = allocPage(1); // еҲҶй…ҚйЎөзӣ®еҪ•иЎЁ
    clear_pgdir(pcb[pcb_idx].pgdir);   // жё…з©ә
    share_pgtable(pcb[pcb_idx].pgdir, pa2kva(PGDIR_PA)); // е…ұдә«еҶ…ж ёжҳ е°„

    // =============================================================
    // [дҝ®ж”№ 3] дҪҝз”Ё map_task еҠ иҪҪ Shell
    // =============================================================
    // д№ӢеүҚеҶҷ load_task_img жҳҜй”ҷзҡ„пјҢиҝҷйҮҢеҝ…йЎ»з”Ё map_task
    uint64_t entry_point = map_task((char *)task_names[0], pcb[pcb_idx].pgdir);
    
    if (entry_point == 0) {
        printk("Error: Task image '%s' not found!\n", task_names[0]);
        while(1); // жүҫдёҚеҲ° Shell зӣҙжҺҘжӯ»еҫӘзҺҜеҒңжӯўпјҢж–№дҫҝи°ғиҜ•
    }

    // =============================================================
    // [дҝ®ж”№ 4] еҲҶй…Қж Ҳе№¶е»әз«Ӣжҳ е°„
    // =============================================================
    
    // еҲҶй…ҚеҶ…ж ёж Ҳ (зӣҙжҺҘеҲҶй…Қзү©зҗҶйЎөпјҢдҪҝз”Ёе…¶еҶ…ж ёиҷҡең°еқҖ)
    pcb[pcb_idx].kernel_stack_base = allocPage(1);
    ptr_t kernel_stack = pcb[pcb_idx].kernel_stack_base + PAGE_SIZE;

    // еҲҶй…Қз”ЁжҲ·ж Ҳ (еҲҶй…Қзү©зҗҶйЎөпјҢе№¶жҳ е°„еҲ°з”ЁжҲ·з©әй—ҙ)
    // A-core USER_STACK_ADDR = 0xf00010000
    // alloc_page_helper дјҡеңЁ pcb[1].pgdir йҮҢе»әз«Ӣжҳ е°„
    uintptr_t user_stack_physical_kva = alloc_page_helper(USER_STACK_ADDR - PAGE_SIZE, pcb[pcb_idx].pgdir);
    pcb[pcb_idx].user_stack_base = user_stack_physical_kva;

    // Shell зҡ„з”ЁжҲ·ж ҲйЎ¶ (еӣәе®ҡдёәз”ЁжҲ·иҷҡең°еқҖ)
    ptr_t final_user_sp = USER_STACK_ADDR;

    // еҲқе§ӢеҢ– PCB еҹәжң¬дҝЎжҒҜ
    pcb[pcb_idx].pid = process_id++;
    pcb[pcb_idx].status = TASK_READY;
    pcb[pcb_idx].cursor_x = 0;
    pcb[pcb_idx].cursor_y = 0;
    pcb[pcb_idx].mask = 0x3; 
    list_init(&pcb[pcb_idx].list);
    list_init(&pcb[pcb_idx].wait_list);

    // =============================================================
    // [дҝ®ж”№ 5] еҲқе§ӢеҢ– TrapFrame
    // =============================================================
    // Shell еҗҜеҠЁдёҚйңҖиҰҒеҸӮж•°пјҢargc=0, argv=NULL
    init_pcb_stack(kernel_stack, final_user_sp, entry_point, &pcb[pcb_idx], 0, NULL);

    // еҠ е…Ҙе°ұз»ӘйҳҹеҲ—
    list_add_tail(&pcb[pcb_idx].list, &ready_queue);

    // -------------------------------------------------------------
    // еҲқе§ӢеҢ– Idle д»»еҠЎ (Core 0 & Core 1)
    // -------------------------------------------------------------
    
    // Core 0 Idle
    pid0_pcb[0].pid = 0;
    pid0_pcb[0].status = TASK_RUNNING;
    pid0_pcb[0].kernel_sp = (reg_t)pid0_stack_core0;
    // Idle д»»еҠЎиҝҗиЎҢеңЁеҶ…ж ёжҖҒпјҢзӣҙжҺҘдҪҝз”ЁеҶ…ж ёж №йЎөиЎЁ
    pid0_pcb[0].pgdir = pa2kva(PGDIR_PA); 
    list_init(&pid0_pcb[0].list);

    // Core 1 Idle
    pid0_pcb[1].pid = 0;
    pid0_pcb[1].status = TASK_RUNNING;
    pid0_pcb[1].kernel_sp = (reg_t)pid0_stack_core1;
    pid0_pcb[1].pgdir = pa2kva(PGDIR_PA);
    list_init(&pid0_pcb[1].list);

    // и®ҫзҪ®еҪ“еүҚиҝҗиЎҢиҝӣзЁӢ
    uint64_t cpu_id = get_current_cpu_id();
    current_running = &pid0_pcb[cpu_id];
}

