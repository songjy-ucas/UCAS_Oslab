long (*syscall[NUM_SYSCALLS])();

void handle_syscall(regs_context_t *regs, uint64_t interrupt, uint64_t cause)
{
    /* TODO: [p2-task3] handle syscall exception */
    /**
     * HINT: call syscall function like syscall[fn](arg0, arg1, arg2),
     * and pay attention to the return value and sepc
     */
    // 1. д»ҺеҜ„еӯҳеҷЁдёӯиҺ·еҸ–зі»з»ҹи°ғз”ЁеҸ· (a7) е’ҢеҸӮж•° (a0, a1, a2, ...)
    long syscall_num = regs->regs[17]; // a7 contains the syscall number
    long arg0 = regs->regs[10];      // a0
    long arg1 = regs->regs[11];      // a1
    long arg2 = regs->regs[12];      // a2
    
    long return_value;

    // 2. жЈҖжҹҘзі»з»ҹи°ғз”ЁеҸ·жҳҜеҗҰжңүж•ҲпјҢе№¶еңЁиЎЁдёӯжҹҘжүҫеҜ№еә”зҡ„еӨ„зҗҶеҮҪж•°
    if (syscall_num >= 0 && syscall_num < NUM_SYSCALLS && syscall[syscall_num] != NULL)
    {
        // 3. и°ғз”ЁжҹҘжүҫеҲ°зҡ„еҮҪж•°гҖӮжҲ‘д»¬дј йҖ’жңҖеӨҡ3дёӘеҸӮж•°пјҢ
        //    еҰӮжһңеҮҪж•°йңҖиҰҒзҡ„еҸӮж•°жӣҙе°‘пјҢеӨҡдҪҷзҡ„еҸӮж•°дјҡиў«еҝҪз•ҘгҖӮ
        return_value = syscall[syscall_num](arg0, arg1, arg2);
    }
    else
    {
        // еҰӮжһңзі»з»ҹи°ғз”ЁеҸ·ж— ж•ҲпјҢжү“еҚ°й”ҷиҜҜдҝЎжҒҜе№¶иҝ”еӣһ-1
        printk("> [SYSCALL] ERROR: Unknown syscall number %d\n", syscall_num);
        return_value = -1;
    }

    // 4. е°Ҷиҝ”еӣһеҖјеӯҳе…Ҙ a0 еҜ„еӯҳеҷЁ
    regs->regs[10] = return_value;

    // 5. е°Ҷ sepc жҢҮеҗ‘ ecall жҢҮд»Өзҡ„дёӢдёҖжқЎжҢҮд»ӨпјҢд»ҘзЎ®дҝқжӯЈзЎ®иҝ”еӣһ
    regs->sepc += 4;
}
