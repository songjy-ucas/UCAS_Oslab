int main(/*int argc, char *argv[]*/)
{   
    // [P3-TASK3] иҺ·еҸ–еҪ“еүҚж ёеҝғ ID
    uint64_t cpu_id = get_current_cpu_id();

    /* 
     * [P4-Task1] е…ій”®дҝ®ж”№: е…ЁеұҖзӯҫеҲ° 
     * жҜҸдёӘж ёиҝӣе…Ҙ main еҮҪж•°пјҢе…ҲеҺҹеӯҗеҠ дёҖпјҢиЎЁзӨәвҖңжҲ‘е·Із»ҸеҲ°иҫҫй«ҳиҷҡжӢҹең°еқҖз©әй—ҙвҖқ
     */
    __sync_fetch_and_add(&cpu_sync_barrier, 1);

    if (cpu_id == 0) {
        // ============ Core 0 еҲқе§ӢеҢ–жөҒзЁӢ ============
        
        // 1. еҲқе§ӢеҢ–е…ЁеұҖж•°жҚ®з»“жһ„
        smp_init(); // еҲқе§ӢеҢ–еӨ§еҶ…ж ёй”Ғ
    
        // current_running = pid0_pcb; // жҢҮеҗ‘ Core 0 зҡ„ idle PCB   --- debug use    
        lock_kernel(); // дёҠеӨ§еҶ…ж ёй”ҒпјҢйҳІжӯў Core 1 жҸҗеүҚиҝҗиЎҢ
        // current_running = NULL; // йҒҝе…ҚиҜҜз”Ё

        // ејәеҲ¶иҪ¬жҚўдёә short жҢҮй’Ҳе№¶еҸ–еҖј
        short num_tasks = *(volatile short *)TASK_NUM_ADDR;
        short task_info_start_sector = *(volatile short *)TASK_INFO_START_ADDR;
        
        /* [P4-Task1] е…ій”®дҝ®ж”№: еҲқе§ӢеҢ–еҶ…еӯҳз®ЎзҗҶеҷЁ */
        // еҝ…йЎ»еңЁеҲҶй…ҚеҶ…еӯҳд№ӢеүҚи°ғз”ЁпјҢеҲқе§ӢеҢ–дҪҚеӣҫе’ҢSwapй“ҫиЎЁ
        init_memory_manager();
        // еҰӮжһңжңү Swap й“ҫиЎЁеҲқе§ӢеҢ–пјҢд№ҹеңЁиҝҷйҮҢ (init_uva_alloc)
        // init_uva_alloc(); 
        
        bss_check();
        init_jmptab(); 
        
        init_task_info(num_tasks, task_info_start_sector);
        
        // init_pcb еҶ…йғЁзҺ°еңЁдҪҝз”Ё allocPage
        init_pcb(); 
        
        // и®ҫзҪ® tp еҜ„еӯҳеҷЁжҢҮеҗ‘ Core 0 зҡ„ current_running
        asm volatile("mv tp, %0" : : "r" (current_running));
        
        time_base = bios_read_fdt(TIMEBASE);
        init_locks();
        init_barriers();   
        init_conditions();
        init_mbox(); 

        printk("> [INIT] PCB initialization succeeded.\n");
        printk("> [INIT] Lock mechanism initialization succeeded.\n");

        asm volatile("csrs sstatus, %[mask]" :: [mask] "r" (SR_SUM));

        init_exception();
        printk("> [INIT] Interrupt processing initialization succeeded.\n");
        init_syscall();
        printk("> [INIT] System call initialized successfully.\n");
        init_screen();
        printk("> [INIT] SCREEN initialization succeeded.\n");
        
        printk("> [INIT] CPU #%u has entered kernel with VM!\n",
            (unsigned int)get_current_cpu_id());
       
        /* [P4-Task1] task1еүҚеҚҠйғЁеҲҶеҗҜз”Ё kernel_brakeпјҢд№ӢеҗҺжіЁйҮҠжҺүеҚіеҸҜ */
        //kernel_brake();
 
        // 2. е”ӨйҶ’ Core 1
        unlock_kernel(); // йҮҠж”ҫеӨ§еҶ…ж ёй”ҒпјҢе…Ғи®ё Core 1 з»§з»ӯжү§иЎҢ
        wakeup_other_hart(); // еҸ‘йҖҒ IPI е”ӨйҶ’ Core 1
        
        /* 
         * [P4-Task1] е…ій”®дҝ®ж”№: зӯүеҫ… Core 1 еҲ°иҫҫ 
         * еңЁеҸ–ж¶Ҳжҳ е°„д№ӢеүҚпјҢеҝ…йЎ»зЎ®дҝқ Core 1 д№ҹе·Із»Ҹиҝӣе…ҘдәҶ main еҮҪж•°пјҲcpu_sync_barrier >= 2пјү
         */
        while (cpu_sync_barrier < 2) {
             asm volatile("nop"); // иҮӘж—Ӣзӯүеҫ…
        }
        
        /* [P4-Task1] е®үе…Ёж—¶еҲ»: зҺ°еңЁеҸ–ж¶Ҳдёҙж—¶жҳ е°„жҳҜе®үе…Ёзҡ„ */
        cancel_identity_mapping();

        // 3. ж Үи®°еҲқе§ӢеҢ–е®ҢжҲҗпјҢе…Ғи®ё Core 1 з»§з»ӯеҗҺз»ӯеҲқе§ӢеҢ–йҖ»иҫ‘
        is_init_finished = 0; 
        
        /* йҖҡзҹҘ Core 1пјҡе…ЁеұҖеҲқе§ӢеҢ–е·Іе®ҢжҲҗпјҢдҪ еҸҜд»Ҙз»§з»ӯдәҶ */
        is_init_finished = 1; 
        asm volatile("fence w, w" ::: "memory"); // еҶҷеұҸйҡң

    } else {
        // ============ Core 1 еҲқе§ӢеҢ–жөҒзЁӢ ============
        
        lock_kernel(); // е°қиҜ•иҺ·еҸ–й”ҒпјҢдјҡеңЁиҝҷйҮҢйҳ»еЎһзӣҙеҲ° Core 0 йҮҠж”ҫй”Ғ
        
        /* 
         * зӯүеҫ… Core 0 е®ҢжҲҗжүҖжңүе…ЁеұҖеҲқе§ӢеҢ– 
         */
        while (is_init_finished == 0) {
            unlock_kernel(); // йҮҠж”ҫй”Ғи®© Core 0 жңүжңәдјҡи·‘ (еҰӮжһңйңҖиҰҒ)
            asm volatile("nop");
            lock_kernel();   // йҮҚж–°жҠўй”Ғ
        }

        asm volatile("fence r, r" ::: "memory"); 

        // 2. и®ҫзҪ® Core 1 зҡ„зҺҜеўғ
        current_running = &pid0_pcb[1];
        asm volatile("mv tp, %0" : : "r" (current_running));
        printk("> [INIT] Core 1 ready to started.\n");
        asm volatile("csrs sstatus, %[mask]" :: [mask] "r" (SR_SUM));

        printk("> [INIT] Core 1 started.\n"); 
        
        unlock_kernel();
    }


    // и®ҫзҪ®еҲқе§Ӣж—¶й’ҹдёӯж–ӯ
    bios_set_timer(get_ticks()+TIMER_INTERVAL);
    // и®ҫзҪ®ејӮеёёе…ҘеҸЈ stvec,е№¶ејҖе…ЁеұҖдёӯж–ӯ
    setup_exception();

    // Infinite while loop
    while (1)
    {
        enable_preempt();
        asm volatile("wfi");
    }

    return 0;
