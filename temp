static void run_pipe_test(char *prog_name)
{
	sys_move_cursor(0, PIPE_TEST_LINE);
	printf("== pipe performance test ==\n");
	char *recv_argv[3] = {prog_name, (char *)"pipe", (char *)"recv"};
	char *send_argv[3] = {prog_name, (char *)"pipe", (char *)"send"};

