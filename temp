#include <os/lock.h>
#include <os/sched.h>
#include <os/list.h>
#include <atomic.h>
#include <os/string.h>

mutex_lock_t mlocks[LOCK_NUM];
// з”ұдәҺ mutex_lock_t з»“жһ„дҪ“жІЎжңүзҠ¶жҖҒеӯ—ж®өпјҢжҲ‘д»¬еҲӣе»әдёҖдёӘе№¶иЎҢзҡ„зҠ¶жҖҒж•°з»„жқҘи·ҹиёӘжҜҸдёӘй”Ғзҡ„зҠ¶жҖҒ
static lock_status_t mlock_status[LOCK_NUM];

// з”ЁдәҺдҝқжҠӨ mlocks ж•°з»„еңЁеҲқе§ӢеҢ–/еҲҶй…ҚиҝҮзЁӢдёӯзҡ„еҺҹеӯҗжҖ§
static spin_lock_t mlock_alloc_lock;


void init_locks(void)
{
    /* TODO: [p2-task2] initialize mlocks */

    spin_lock_init(&mlock_alloc_lock);
    for (int i = 0; i < LOCK_NUM; i++)
    {
        spin_lock_init(&mlocks[i].lock);
        list_init(&mlocks[i].block_queue);
        mlocks[i].key = -1; // -1 иЎЁзӨәиҜҘй”Ғж§ҪдҪҚжңӘдҪҝз”Ё
        mlock_status[i] = UNLOCKED;
    }
}

void spin_lock_init(spin_lock_t *lock)
{
    /* TODO: [p2-task2] initialize spin lock */
    lock->status = UNLOCKED;
}

int spin_lock_try_acquire(spin_lock_t *lock)
{
    /* TODO: [p2-task2] try to acquire spin lock */
    return (atomic_swap(LOCKED, (ptr_t)&lock->status) == UNLOCKED);
}

void spin_lock_acquire(spin_lock_t *lock)
{
    /* TODO: [p2-task2] acquire spin lock */
    while (!spin_lock_try_acquire(lock))
    {
        // loop and wait
    }
}

void spin_lock_release(spin_lock_t *lock)
{
    /* TODO: [p2-task2] release spin lock */
    lock->status = UNLOCKED;
}

int do_mutex_lock_init(int key)
{
    /* TODO: [p2-task2] initialize mutex lock */
    spin_lock_acquire(&mlock_alloc_lock);

    // жҹҘжүҫжҳҜеҗҰе·ІеӯҳеңЁеҹәдәҺжӯӨ key зҡ„й”Ғ
    for (int i = 0; i < LOCK_NUM; i++)
    {
        if (mlocks[i].key == key)
        {
            spin_lock_release(&mlock_alloc_lock);
            return i; // иҝ”еӣһе·ІеӯҳеңЁзҡ„й”Ғзҡ„еҸҘжҹ„ (зҙўеј•)
        }
    }

    // жҹҘжүҫдёҖдёӘжңӘдҪҝз”Ёзҡ„й”Ғж§ҪдҪҚиҝӣиЎҢеҲқе§ӢеҢ–
    int lock_idx = -1;
    for (int i = 0; i < LOCK_NUM; i++)
    {
        if (mlocks[i].key == -1)
        {
            mlocks[i].key = key;
            lock_idx = i;
            break;
        }
    }

    spin_lock_release(&mlock_alloc_lock);
    return lock_idx; // иҝ”еӣһж–°й”Ғзҡ„еҸҘжҹ„пјҢеҰӮжһңжІЎжүҫеҲ°еҲҷиҝ”еӣһ-1
 
}

void do_mutex_lock_acquire(int mlock_idx)
{
    /* TODO: [p2-task2] acquire mutex lock */
    if (mlock_idx < 0 || mlock_idx >= LOCK_NUM) return;

    mutex_lock_t *lock = &mlocks[mlock_idx];

    while (1) {
        // дҪҝз”ЁиҮӘж—Ӣй”ҒдҝқжҠӨеҜ№й”ҒзҠ¶жҖҒе’Ңйҳ»еЎһйҳҹеҲ—зҡ„и®ҝй—®
        spin_lock_acquire(&lock->lock);

        if (mlock_status[mlock_idx] == UNLOCKED)
        {
            // й”ҒжҳҜеҸҜз”Ёзҡ„пјҢиҺ·еҸ–е®ғе№¶з«ӢеҚіиҝ”еӣһ
            mlock_status[mlock_idx] = LOCKED;
            lock->pid = current_running->pid;
            spin_lock_release(&lock->lock);
            return;
        }
        else
        {
            // й”Ғиў«еҚ з”ЁпјҢе°ҶеҪ“еүҚиҝӣзЁӢйҳ»еЎһ
            do_block(&current_running->list, &lock->block_queue);
            // йҮҠж”ҫиҮӘж—Ӣй”ҒпјҢе…Ғи®ёе…¶д»–иҝӣзЁӢпјҲзү№еҲ«жҳҜжҢҒжңүй”Ғзҡ„иҝӣзЁӢпјүиҝҗиЎҢ
            spin_lock_release(&lock->lock);
            // и°ғз”Ёи°ғеәҰеҷЁеҲҮжҚўиҝӣзЁӢ
            do_scheduler();
            // иў«е”ӨйҶ’еҗҺпјҢеҫӘзҺҜеҶҚж¬Ўе°қиҜ•иҺ·еҸ–й”Ғ
        }
    }
}

void do_mutex_lock_release(int mlock_idx)
{
    /* TODO: [p2-task2] release mutex lock */
    if (mlock_idx < 0 || mlock_idx >= LOCK_NUM) return;

    mutex_lock_t *lock = &mlocks[mlock_idx];

    spin_lock_acquire(&lock->lock);
    if (lock->pid == current_running->pid) { // е®үе…ЁжЈҖжҹҘпјҡеҸӘжңүжҢҒжңүиҖ…жүҚиғҪйҮҠж”ҫй”Ғ
    mlock_status[mlock_idx] = UNLOCKED;
    lock->pid = -1; // <<-- жё…йҷӨжҢҒжңүиҖ…пјҒ
    if (!list_empty(&lock->block_queue)) {
        do_unblock(lock->block_queue.next);
    }
}
    spin_lock_release(&lock->lock);
}

// иҫ…еҠ©еҮҪж•°пјҡйҮҠж”ҫй”Ғ
void check_and_release_locks(pid_t pid)
{
    // йҒҚеҺҶжүҖжңүеҸҜиғҪзҡ„дә’ж–Ҙй”Ғ
    for (int i = 0; i < LOCK_NUM; ++i) {
        mutex_lock_t *lock = &mlocks[i];
        
        // 1. иҺ·еҸ–иҮӘж—Ӣй”ҒпјҢдҝқиҜҒж“ҚдҪңеҺҹеӯҗжҖ§
        // иҷҪз„¶иў«жқҖзҡ„иҝӣзЁӢдёҚдјҡеҶҚеҠЁпјҢдҪҶе…¶д»–иҝӣзЁӢеҸҜиғҪжӯЈеңЁи®ҝй—®иҝҷдёӘй”Ғзҡ„йҳҹеҲ—
        spin_lock_acquire(&lock->lock);

        // 2. жЈҖжҹҘжқЎд»¶пјҡй”Ғеҝ…йЎ»жҳҜ LOCKED зҠ¶жҖҒпјҢдё”жҢҒжңүиҖ… PID еҝ…йЎ»еҢ№й…Қ
        if (mlock_status[i] == LOCKED && lock->pid == pid) {
            
            // 3. ејәеҲ¶йҮҠж”ҫй”Ғ
            mlock_status[i] = UNLOCKED;
            lock->pid = -1; // жё…йҷӨжҢҒжңүиҖ…

            // 4. жЈҖжҹҘзӯүеҫ…йҳҹеҲ—пјҢеҰӮжһңжңүзӯүеҫ…иҖ…пјҢе”ӨйҶ’е®ғ
            if (!list_empty(&lock->block_queue)) {
                // еҸ–еҮәзӯүеҫ…йҳҹеҲ—зҡ„з¬¬дёҖдёӘиҠӮзӮ№
                list_node_t *waiter = lock->block_queue.next;
                
                // и°ғз”Ё sched.c дёӯзҡ„ unblock е°Ҷе…¶з§»еӣһе°ұз»ӘйҳҹеҲ—
                // жіЁж„ҸпјҡеңЁ Mesa з®ЎзЁӢиҜӯд№үдёӢпјҢе”ӨйҶ’зҡ„иҝӣзЁӢдјҡеҶҚж¬Ўе°қиҜ• atomic_swap иҺ·еҸ–й”Ғ
                // еӣ дёәжҲ‘д»¬е°ҶзҠ¶жҖҒи®ҫдёәдәҶ UNLOCKEDпјҢе®ғеә”иҜҘиғҪжҲҗеҠҹ
                do_unblock(waiter);
            }
        }
        
        // 5. йҮҠж”ҫиҮӘж—Ӣй”Ғ
        spin_lock_release(&lock->lock);
    }
}
