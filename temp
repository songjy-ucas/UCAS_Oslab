    usepage = 0;                             // е·ІеҲҶй…ҚйЎөйқўи®Ўж•°еҷЁжё…йӣ¶
    // еҰӮжһңйңҖиҰҒпјҢеҸҜд»ҘеңЁиҝҷйҮҢеҲқе§ӢеҢ–еҶ…ж ёдҝқз•ҷеҢә
    // [P4-TASK3 START]
    init_uva_alloc(); // еҲқе§ӢеҢ–жҚўйЎөе…ғж•°жҚ®
    // [P4-TASK3 END]
}

// жЈҖжҹҘзү©зҗҶеҶ…еӯҳжҳҜеҗҰе·Іе®Ңе…Ёз”Ёж»Ў
bool is_memory_full()
{
    for (int i = 0; i < TOTAL_PAGES / 8; i++) {
        if (page_bitmap[i] != 0xff) { // 0xff иЎЁзӨәдёҖдёӘеӯ—иҠӮпјҲ8дёӘйЎөпјүйғҪе·ІеҲҶй…Қ
            return false;
        }
    }
    return true;
}

// еҲҶй…ҚжҢҮе®ҡж•°йҮҸзҡ„зү©зҗҶйЎөйқў
ptr_t allocPage(int numPage)
{
    // еҜ№йҪҗеҲ°йЎөйқўеӨ§е°Ҹ
    ptr_t ret = ROUND(kernMemCurr, PAGE_SIZE);
    
    int count = 0;
    // з®ҖеҚ•зҡ„йҳІжӯўжӯ»еҫӘзҺҜдҝқжҠӨжңәеҲ¶
    int max_checks = (TOTAL_PAGES / numPage) * 2; 

    // зәҝжҖ§жү«жҸҸжҹҘжүҫз©әй—ІйЎө
    do {
        ret = ROUND(kernMemCurr, PAGE_SIZE);
        kernMemCurr = ret + numPage * PAGE_SIZE;
        
        // еҰӮжһңжү«жҸҸеҲ°еҶ…еӯҳжң«е°ҫпјҢеҲҷд»ҺеӨҙејҖе§Ӣ
        if (kernMemCurr >= KERNELMEM_END) {
            kernMemCurr = FREEMEM_KERNEL;
            if (is_memory_full()) {
                // [P4-TASK3 START] еҶ…еӯҳж»ЎдәҶпјҢе°қиҜ•жҚўйЎөиҖҢдёҚжҳҜзӣҙжҺҘеҙ©жәғ
                if (list_empty(&in_mem_list)) {
                    printk("Fatal: Memory Full and no page to swap out!\n");
                    assert(0);
                }
                swapPage(); // жҚўеҮәдёҖйЎөдёәallocPageи…ҫеҮәз©әй—ҙ
                // [P4-TASK3 END]
            }
        }
        
        count++;
        if (count > max_checks) {
            printk("Fatal: AllocPage Timeout!\n");
            assert(0); // еҰӮжһңжү«жҸҸж¬Ўж•°иҝҮеӨҡпјҢеҸҜиғҪеҮәзҺ°й—®йўҳпјҢж–ӯиЁҖеӨұиҙҘ
        }

    } while(page_bitmap[BITMAP(ret)] & (1 << (BITMAP_OFFSET(ret)))); // жЈҖжҹҘдҪҚеӣҫпјҢзӣҙеҲ°жүҫеҲ°з©әй—ІйЎө

    // ж Үи®°дҪҚеӣҫпјҢиЎЁзӨәиҝҷдәӣйЎөе·Іиў«еҲҶй…Қ
    for(int i=0; i<numPage; i++){
        page_bitmap[BITMAP(ret + i*PAGE_SIZE)] |= (1 << (BITMAP_OFFSET(ret + i*PAGE_SIZE)));
    }
    
    usepage += numPage; // жӣҙж–°е·ІеҲҶй…ҚйЎөйқўи®Ўж•°
    // е°Ҷж–°еҲҶй…Қзҡ„йЎөйқўжё…йӣ¶пјҢйҳІжӯўж®Ӣз•ҷж•°жҚ®
    memset((void*)ret, 0, numPage * PAGE_SIZE);
    return ret; // иҝ”еӣһеҲҶй…ҚеҲ°зҡ„йЎөйқўзҡ„иө·е§ӢеҶ…ж ёиҷҡжӢҹең°еқҖ
}

// е…је®№жҺҘеҸЈпјҡеҲҶй…ҚеҶ…ж ёйЎөйқў
ptr_t allocKernelPage(int numPage) { return allocPage(numPage); }
