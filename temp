/**
 * @brief д»Һз»Ҳз«ҜиҜ»еҸ–дёҖдёӘж•ҙж•°гҖӮ
 * ж”ҜжҢҒйҖҖж јй”®еҲ йҷӨгҖӮ
 * @return иҜ»еҸ–еҲ°зҡ„ж•ҙж•°гҖӮ
 */
static int read_int_from_terminal()
{
    char buffer[32];
    int i = 0;
    while (i < sizeof(buffer) - 1) {
        int ch = -1;
        while(ch == -1) {
            ch = bios_getchar();
        }

        if (ch == '\r' || ch == '\n') {
            break;
        } else if (ch == 8 || ch == 127) { // йҖҖж јй”®
            if (i > 0) {
                i--;
                bios_putchar(8); bios_putchar(' '); bios_putchar(8);
            }
        } else if (ch >= '0' && ch <= '9') {
            buffer[i++] = (char)ch;
            bios_putchar((char)ch);
        }
    }
    buffer[i] = '\0';
    bios_putstr("\n\r");

    // з®Җжҳ“зҡ„ atoi е®һзҺ°
    int result = 0;
    for (i = 0; buffer[i] != '\0'; ++i) {
        result = result * 10 + (buffer[i] - '0');
    }
    return result;
}

int main()
{
    // е®ҡд№үдёҖдёӘжҢҮеҗ‘е…ұдә«еҶ…еӯҳең°еқҖзҡ„жҢҮй’Ҳ
    volatile int *shared_data = (int *)SHARED_MEM_ADDR;

    bios_putstr("I am prog1. Please input an integer: ");
    
    // д»Һз»Ҳз«ҜиҜ»еҸ–дёҖдёӘж•ҙж•°
    int input_number = read_int_from_terminal();

    // е°Ҷж•ҙж•°еҶҷе…Ҙе…ұдә«еҶ…еӯҳ
    *shared_data = input_number;

    return 0; // йҖҖеҮәпјҢжҺ§еҲ¶жқғдәӨиҝҳеҶ…ж ё
}
