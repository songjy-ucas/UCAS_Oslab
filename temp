#include <os/debug.h> // еҢ…еҗ« printk е®ҡд№ү
#include <csr.h>    // еҢ…еҗ« CSR е®ҡд№ү

void debug_trap_handler(unsigned long scause, unsigned long stval, unsigned long sepc) {
    // иҝҮж»ӨжҺүж—¶й’ҹдёӯж–ӯ (SжҖҒж—¶й’ҹдёӯж–ӯйҖҡеёёжҳҜ 0x8000...005)
    // д№ҹеҸҜд»Ҙж №жҚ®дҪ зҡ„йңҖиҰҒиҝҮж»ӨжҺүе…¶д»–дёӯж–ӯ
    if ((scause & SCAUSE_IRQ_FLAG) && ((scause & 0xff) == IRQ_S_TIMER)) {
        return; 
    }

    klog("[Trap Debug] scause: 0x%lx, stval: 0x%lx, sepc: 0x%lx\n", 
           scause, stval, sepc);
    
    // еҰӮжһңжҳҜзјәйЎөејӮеёё (12, 13, 15)пјҢеҸҜд»Ҙжү“еҚ°жӣҙйҶ’зӣ®дёҖзӮ№
    if (scause == 12 || scause == 13 || scause == 15) {
        klog("    -> Page Fault at 0x%lx\n", stval);
    }
    // еҰӮжһңжҳҜзі»з»ҹи°ғз”Ё (8)пјҢжү“еҚ°дёҖдёӢ
    if (scause == 8) {
        klog("    -> Syscall at 0x%lx\n", sepc);
    }
}END OF FILE: arch/riscv/kernel/trap.c

