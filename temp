int usepage = 0;
// е…ЁеұҖеҸҳйҮҸпјҢз”ЁдәҺеңЁжҚўйЎөж—¶и®°еҪ•еҪ“еүҚж“ҚдҪңзҡ„иҝӣзЁӢзҡ„йЎөиЎЁзӣ®еҪ•IDпјҲеңЁеӨҡиҝӣзЁӢеңәжҷҜдёӢеҸҜиғҪйңҖиҰҒж”№иҝӣпјү
int pgdir_id; 

// е®ҡд№үеҸҜз”ЁдәҺеҠЁжҖҒеҲҶй…Қзҡ„зү©зҗҶеҶ…еӯҳзҡ„жҖ»йЎөж•°
#define TOTAL_PAGES 65536         
// еҶ…ж ёеҸҜеҠЁжҖҒеҲҶй…ҚеҶ…еӯҳеҢәеҹҹзҡ„иҷҡжӢҹең°еқҖиө·е§ӢзӮ№
#define KERNELMEM_START 0xffffffc050000000lu 
// еҶ…ж ёеҸҜеҠЁжҖҒеҲҶй…ҚеҶ…еӯҳеҢәеҹҹзҡ„иҷҡжӢҹең°еқҖз»“жқҹзӮ№
#define KERNELMEM_END   0xffffffc060000000lu

// е®Ҹпјҡж №жҚ®еҶ…ж ёиҷҡжӢҹең°еқҖи®Ўз®—е…¶еңЁ page_bitmap дёӯзҡ„еӯ—иҠӮзҙўеј•
#define BITMAP(n) ((n - KERNELMEM_START) / (8 * PAGE_SIZE))
// е®Ҹпјҡж №жҚ®еҶ…ж ёиҷҡжӢҹең°еқҖи®Ўз®—е…¶еңЁ page_bitmap еҜ№еә”еӯ—иҠӮдёӯзҡ„дҪҚеҒҸз§»
#define BITMAP_OFFSET(n) (((n - KERNELMEM_START) / PAGE_SIZE) % 8)

// е…ЁеұҖдҪҚеӣҫпјҢз”ЁдәҺи·ҹиёӘжҜҸдёӘзү©зҗҶйЎөжЎҶзҡ„дҪҝз”ЁзҠ¶жҖҒ (0: з©әй—І, 1: е·ІдҪҝз”Ё)
static uint8_t page_bitmap[TOTAL_PAGES / 8];

// [P4-TASK3 START] ж–°еўһиҫ…еҠ©еҮҪж•°еЈ°жҳҺ
