        // [HISTORY] жҜҸж¬Ўж–°еҫӘзҺҜејҖе§Ӣж—¶пјҢйҮҚзҪ®еҪ“еүҚеҺҶеҸІжҢҮй’ҲеҲ°жңҖж–°дҪҚзҪ®
        history_current = history_count;

        printf("> root@UCAS_OS: ");
        sys_reflush();
