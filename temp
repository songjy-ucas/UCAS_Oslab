// з”ЁдәҺиҜ»еҸ–CSRеҜ„еӯҳеҷЁзҡ„е®Ҹ
#define read_csr(reg)                                       \
    ({                                                      \
        unsigned long __tmp;                                \
        asm volatile("csrr %0, " #reg : "=r"(__tmp));        \
        __tmp;                                              \
    })

// з”ЁдәҺеҶҷе…ҘCSRеҜ„еӯҳеҷЁзҡ„е®Ҹ
#define write_csr(reg, val)                                 \
    ({                                                      \
        asm volatile("csrw " #reg ", %0" ::"rK"(val));       \
    })

// з”ЁдәҺеңЁCSRеҜ„еӯҳеҷЁдёӯи®ҫзҪ®жҹҗдәӣдҪҚзҡ„е®Ҹ (set bits)
#define set_csr(reg, bits)                                  \
    ({                                                      \
        asm volatile("csrs " #reg ", %0" ::"rK"(bits));      \
    })

// з”ЁдәҺеңЁCSRеҜ„еӯҳеҷЁдёӯжё…йҷӨжҹҗдәӣдҪҚзҡ„е®Ҹ (clear bits)
#define clear_csr(reg, bits)                                \
    ({                                                      \
        asm volatile("csrc " #reg ", %0" ::"rK"(bits));      \
    })

#endif /* CSR_H */
